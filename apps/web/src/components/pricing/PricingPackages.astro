---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Icons
import Check from "@/components/fundations/icons/Check.astro";
const pricingPackages = [
  {
    name: "Small Business",
    description: "For startups and businesses with simple accounting needs",
    price: "$2,400",
    period: "/year",
    additionalPricing: "+ Quarterly tax planning: $800/year",
    features: [
      "Monthly bookkeeping & reconciliation",
      "Annual financial statements",
      "Tax planning & preparation support",
      "Email & phone support",
      "Up to 500 transactions/year",
    ],
    isPopular: false,
    buttonText: "Get Started",
    buttonVariant: "default",
  },
  {
    name: "Mid-Market Business",
    description:
      "For established businesses with complex accounting requirements",
    price: "$6,000",
    period: "/year",
    additionalPricing: "+ Monthly CFO consultation: $1,200/year",
    features: [
      "Everything in Small Business, plus:",
      "Management reporting & financial analysis",
      "Tax planning & strategy (monthly)",
      "Budgeting & cash flow forecasting",
      "Up to 2,000 transactions/year",
      "Dedicated account manager",
    ],
    isPopular: true,
    buttonText: "Get Started",
    buttonVariant: "accent",
  },
  {
    name: "Large Enterprise",
    description: "Comprehensive accounting solutions for large organizations",
    price: "Custom",
    period: "",
    additionalPricing: "Tailored pricing based on your specific needs",
    features: [
      "Everything in Mid-Market Business, plus:",
      "Multi-entity accounting & consolidation",
      "Audit preparation & support",
      "CFO services & strategic financial planning",
      "Unlimited transactions & custom integrations",
      "Dedicated accounting team & priority support",
    ],
    isPopular: false,
    buttonText: "Schedule Consultation",
    buttonVariant: "default",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-12">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-start">
      <Kicker variant="default">Packages</Kicker>
      <Text
        tag="h2"
        variant="displayMD"
        class="text-base-900 text-balance font-medium tracking-tight font-display lg:col-span-2 lg:-mt-2"
      >
        Accounting Service Packages
      </Text>
      <Text
        tag="p"
        variant="textLG"
        class="text-base-900 lg:text-pretty lg:col-span-2"
      >
        Professional accounting solutions tailored to your business size and
        complexity
      </Text>
    </div>
    <div
      class="grid grid-cols-1 lg:grid-cols-3 gap-4 lg:gap-y-12 mt-12 p-8 lg:p-12 bg-base-50"
    >
      {
        pricingPackages.map((pkg, index) => (
          <div class="bg-white p-8 relative flex flex-col justiffy-between h-full">
            <div>
              <div>
                <div>
                  <div class="flex items-end justify-between">
                    <div>
                      <Text
                        tag="span"
                        variant="displaySM"
                        class="text-base-900  font-display"
                      >
                        {pkg.price}
                      </Text>
                      <Text tag="span" variant="textSM" class="text-base-700 ">
                        {pkg.period}
                      </Text>
                    </div>
                    {pkg.isPopular && (
                      <span class="bg-white text-accent-500 text-sm font-medium">
                        Most Popular
                      </span>
                    )}
                  </div>
                  <Text tag="p" variant="textXS" class="text-base-500 mt-2">
                    {pkg.additionalPricing}
                  </Text>
                </div>
                <div class="mt-8">
                  <Text
                    tag="h3"
                    variant="textXL"
                    class="text-base-900 font-display"
                  >
                    {pkg.name}
                  </Text>
                  <Text tag="p" variant="textSM" class="text-base-600 ">
                    {pkg.description}
                  </Text>
                </div>
                <Button
                  variant={pkg.buttonVariant}
                  size="sm"
                  isLink={true}
                  href="/contact"
                  class="w-full mt-8"
                >
                  {pkg.buttonText}
                </Button>
              </div>
              <ul class="space-y-2 mt-8">
                {pkg.features.map((feature) => (
                  <li class="flex items-start gap-3">
                    <Check class="size-4" />
                    <Text tag="span" variant="textSM" class="text-base-600">
                      {feature}
                    </Text>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
