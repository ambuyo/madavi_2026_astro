---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Icons
import Plus from "@/components/fundations/icons/Plus.astro";
// FAQ Data Structure
const faqData = [
  {
    category: "Pricing & Billing",
    questions: [
      {
        question: "What's included in the setup fee?",
        answer:
          "The one-time setup fee covers initial account configuration, data migration from your existing systems, custom report setup, and training for your team on our processes and tools.",
      },
      {
        question: "Can I change packages as my business grows?",
        answer:
          "Absolutely! You can upgrade or downgrade your package at any time. We'll work with you to ensure a smooth transition with no disruption to your accounting services.",
      },
      {
        question: "Do you offer payment plans?",
        answer:
          "Yes, we offer flexible payment terms for our monthly packages. Individual services can be paid upfront or through installment plans depending on the scope and timeline.",
      },
      {
        question: "What if I need services not listed here?",
        answer:
          "We offer custom accounting solutions for unique business needs. Contact us to discuss your specific requirements, and we'll provide a tailored quote and service plan.",
      },
    ],
  },
];
---
<section>
  <Wrapper variant="standard" class="py-12">
    <div class="max-w-2xl">
      <Kicker variant="default">Pricing FAQ</Kicker>
      <Text
        tag="h2"
        variant="displayLG"
        class="text-base-900 text-balance font-medium tracking-tight mt-8 font-display"
      >
        Frequently Asked Questions
      </Text>
      <Text
        tag="p"
        variant="textBase"
        class="text-base-600 lg:text-balance mt-4"
      >
        Find answers to common questions about our pricing, billing, and service
        packages.
      </Text>
    </div>
    <div class="space-y-8 gap-8 mt-12 ">
      {
        faqData.map((category) => (
          <div class="p-8 lg:p-12 bg-base-50">
            <Text
              tag="h3"
              variant="textXL"
              class="text-base-900 text-balance font-medium tracking-tight font-display"
            >
              {category.category}
            </Text>
            <div class="divide-y divide-base-100 border-y border-base-100 mt-2 text-balance">
              {category.questions.map((faq) => (
                <details class="group">
                  <summary class="cursor-pointer py-4 text-base font-medium text-base-900 hover:text-accent-500 transition-colors grid grid-cols-1 lg:grid-cols-2 select-none ">
                    {faq.question}
                    <Plus class="size-5 hidden lg:block transition-transform group-open:rotate-180 duration-300 ml-auto" />
                  </summary>
                  <div class="pb-4  text-base-600">{faq.answer}</div>
                </details>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
