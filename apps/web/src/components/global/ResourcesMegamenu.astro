---
// Assets
import Shield from "@/components/assets/Shield.astro";
import { Image } from "astro:assets";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
// Icons
import ArrowRight from "@/components/fundations/icons/ArrowRight.astro";

const resources = [
  {
    title: "Events & Summits",
    description: "Our upcoming events and recordings",
    href: "/resources/events",
    icon: "🎤",
  },
  {
    title: "Customer Stories",
    description: "Behind the successful partnerships",
    href: "/resources/customer-stories",
    icon: "📋",
  },
  {
    title: "Guides",
    description: "Insights from marketing leaders",
    href: "/resources/guides",
    icon: "📖",
  },
  {
    title: "Reports",
    description: "Data for smarter decisions",
    href: "/resources/reports",
    icon: "📊",
  },
  {
    title: "Blog",
    description: "Long-form you can learn from",
    href: "/blog",
    icon: "📝",
  },
];

const latestMedia = [
  {
    title: "The AI Reset: A Playbook for Bringing AI to Your Creative Team",
    href: "/resources/the-ai-reset",
    image: "https://via.placeholder.com/400x300?text=AI+Reset",
  },
  {
    title: "From AI uncertainty to creative superpower: 6 lessons from Superside's Shift summit",
    href: "/resources/superside-shift-summit",
    image: "https://via.placeholder.com/400x300?text=Superside+Shift",
  },
];
---

<div
  id="resources-megamenu"
  class="hidden fixed left-0 right-0 top-[73px] z-40 md:max-h-none max-h-[calc(100vh-73px)] overflow-y-auto bg-white"
>
  <div class="flex justify-center">
    <div class="w-full max-w-7xl px-8 lg:px-12 py-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Left Column: Resources -->
        <div>
          <Text
            tag="h3"
            variant="textLG"
            class="text-base-900 font-semibold mb-8"
          >
            Our resources
          </Text>
          <div class="space-y-6">
            {
              resources.map((resource) => (
                <a
                  href={resource.href}
                  class="group flex items-start gap-4 pb-6 border-b border-base-200 hover:border-accent-400 transition-colors"
                >
                  <div class="flex-shrink-0 text-2xl">
                    {resource.icon}
                  </div>
                  <div class="flex-grow">
                    <Text
                      tag="h4"
                      variant="textBase"
                      class="text-base-900 font-semibold group-hover:text-accent-600 transition-colors"
                    >
                      {resource.title}
                    </Text>
                    <Text
                      tag="p"
                      variant="textSM"
                      class="text-base-600 mt-1"
                    >
                      {resource.description}
                    </Text>
                  </div>
                </a>
              ))
            }
          </div>
        </div>

        <!-- Right Column: Latest Media -->
        <div>
          <Text
            tag="h3"
            variant="textLG"
            class="text-base-900 font-semibold mb-8"
          >
            Latest media
          </Text>
          <div class="space-y-6">
            {
              latestMedia.map((media) => (
                <a
                  href={media.href}
                  class="group block overflow-hidden rounded-lg"
                >
                  <div class="relative bg-base-200 aspect-video overflow-hidden rounded-lg mb-4">
                    <div class="w-full h-full bg-gradient-to-br from-accent-400 to-accent-600 flex items-center justify-center text-white">
                      <Text
                        tag="p"
                        variant="textSM"
                        class="text-center px-4"
                      >
                        {media.title}
                      </Text>
                    </div>
                  </div>
                  <Text
                    tag="h4"
                    variant="textBase"
                    class="text-base-900 font-semibold group-hover:text-accent-600 transition-colors line-clamp-2"
                  >
                    {media.title}
                  </Text>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
