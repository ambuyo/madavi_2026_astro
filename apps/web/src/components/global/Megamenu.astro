    <div class="w-full max-w-7xl px-12 py-12">
      <div
        class="grid grid-cols-2 gap-y-8 lg:grid-cols-5 lg:divide-x divide-base-900 p-0"
      >
        {
          resourcesMegamenuSections.map((section) => (
            <div class="px-6">
              <a
                href={section.href}
