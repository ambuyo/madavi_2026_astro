---
// Assets
import Shield from "@/components/assets/Shield.astro";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Icons
import ArrowRight from "@/components/fundations/icons/ArrowRight.astro";
// Megamenu sections
const megamenuSections = [
  {
    title: "Overview",
    href: "/system/overview",
    links: [
      { href: "/system/overview", label: "All Pages" },
      { href: "/system/buttons", label: "Buttons" },
      { href: "/system/colors", label: "Colors" },
      { href: "/system/link", label: "Links" },
      { href: "/system/typography", label: "Typography" },
    ],
  },
  {
    title: "Services",
    href: "/services",
    links: [
      { href: "/services", label: "Explore All Services" },
      {
        href: "/services/bookkeeping-accounting",
        label: "Bookkeeping & Accounting",
      },
      {
        href: "/services/business-valuation-appraisal",
        label: "Business Valuation",
      },
      {
        href: "/services/audit-support-assurance",
        label: "Audit Support & Assurance",
      },
      {
        href: "/services/business-formation-setup",
        label: "Business Formation & Setup",
      },
      {
        href: "/services/bankruptcy-financial-restructuring-accounting",
        label: "Bankruptcy & Restructuring",
      },
      {
        href: "/services/agricultural-accounting-farm-management",
        label: "Agricultural Accounting",
      },
    ],
  },
  {
    title: "Industries We Serve",
    href: "/industries",
    links: [
      { href: "/industries", label: "All Industries" },
      {
        href: "/industries/technology-software",
        label: "Technology & Software",
      },
      { href: "/industries/healthcare-medical", label: "Healthcare & Medical" },
      {
        href: "/industries/manufacturing-industrial",
        label: "Manufacturing & Industrial",
      },
      { href: "/industries/retail-ecommerce", label: "Retail & E-commerce" },
      {
        href: "/industries/professional-services",
        label: "Professional Services",
      },
      {
        href: "/industries/real-estate-property",
        label: "Real Estate & Property",
      },
      {
        href: "/industries/construction-development",
        label: "Construction & Development",
      },
    ],
  },
  {
    title: "Resources",
    href: "/blog",
    links: [
      { href: "/blog", label: "Blog & Insights" },
      { href: "/case-studies", label: "Case Studies" },
      { href: "/pricing", label: "Pricing & Plans" },
      { href: "/faq", label: "Help Center & FAQs" },
      { href: "/about", label: "About Us" },
      { href: "/contact", label: "Contact" },
      { href: "/faq", label: "FAQ" },
    ],
  },
];
---

<div
  id="megamenu"
  class="hidden group-hover/megamenu:block fixed left-0 right-0 top-[73px] z-40 md:max-h-none max-h-[calc(100vh-73px)] overflow-y-auto bg-black"
>
  <div class="flex justify-center">
    <div class="w-full max-w-7xl px-12 py-12">
      <div
        class="grid grid-cols-2 gap-y-8 lg:grid-cols-5 lg:divide-x divide-base-900 p-0"
      >
      <div
        class="p-8 bg-accent-400 flex flex-col h-full justify-between gap-12 lg:gap-18 col-span-full lg:col-span-1"
      >
        <div>
          <Shield class="h-6 text-white" />
          <Text
            tag="h3"
            variant="displaySM"
            class="text-base text-white mt-8 font-display font-medium"
          >
            Get in touch
          </Text>
          <Text tag="p" variant="textSM" class="text-white font-medium mt-2">
            Get in touch with us to learn more about our services and how we can
            help you.
          </Text>
        </div>
        <Button
          variant="muted"
          size="xs"
          isLink={true}
          href="/contact"
          class="w-fit"
        >
          Contact Us
        </Button>
      </div>
      {
        megamenuSections.map((section) => (
          <div class="px-6">
            <a
              href={section.href}
              class="group flex items-center justify-between text-white uppercase hover:text-accent-400 transition-colors"
            >
              <Text tag="h3" variant="textSM">
                {section.title}
              </Text>
              <ArrowRight class="size-4 " />
            </a>
            <ul class="space-y-2 mt-4 lg:mt-12">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="group text-xs flex items-center text-base-300 hover:text-accent-500 transition-colors duration-300 justify-between"
                  >
                    {link.label}
                    <ArrowRight class="size-4 hidden group-hover:flex duration-300" />
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
      <div
        class="border-t pt-4 border-base-900 col-span-full flex flex-col lg:flex-row gap-4 lg:items-center lg:justify-between"
      >
        <div class="flex flex-wrap gap-4 items-center">
          <a
            href="tel:+1-555-123-4567"
            class="text-base-400 text-xs hover:text-white-400 transition-colors"
          >
            +1 (555) 123-4567
          </a>
          <span class="hidden md:flex text-base-900">|</span>
          <address class="text-base-400 not-italic text-xs">
            123 Business Street, Suite 100, New York, NY 10001
          </address>
        </div>
        <div
          class="flex flex-wrap gap-4 items-center order-first lg:order-none"
        >
          <a
            href="#_"
            class="text-base-400 text-xs hover:text-white-400 transition-colors"
          >
            X
          </a>
          <a
            href="#_"
            class="text-base-400 text-xs hover:text-white-400 transition-colors"
          >
            LinkedIn
          </a>
          <a
            href="#_"
            class="text-base-400 text-xs hover:text-white-400 transition-colors"
          >
            Email
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
