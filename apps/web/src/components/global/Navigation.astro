---
// Assets
import Logo from "@/components/assets/Logo.astro";
// Fundations
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import Search from "@/components/global/Search.astro";
import MobileNav from "@/components/global/MobileNav.astro";
import MegaMenu from "@/components/global/MegaMenu.astro";

// Navigation links
const navLinks = [
  { label: "Services", href: "/ai-services" },
  { label: "Industries", href: "/industries" },
    { label: "Resources", href: "#" },
  { label: "Case Studies", href: "/case-studies" },
  { label: "Team", href: "/team" },
  { label: "Blog", href: "/blog" },
  { label: "Contact", href: "/#contact" },
];
---

<header class="fixed inset-x-0 top-0 z-50 bg-white">
  <Wrapper variant="standard" class="py-6">
    <div class="flex items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-3 text-base-900 max-w-xs">
        <Logo class="h-16 w-auto" />
      </a>
      <nav class="hidden items-center gap-8 lg:flex group" aria-label="Primary">
        {
          navLinks.map((link) => {
            const hasMegamenu = link.label === "Services" || link.label === "Industries" || link.label === "Resources";
            return (
              <a
                href={link.href}
                class={`text-sm font-medium text-base-700 transition-colors hover:text-base-950 ${hasMegamenu ? "has-megamenu" : ""}`}
              >
                {link.label}
              </a>
            );
          })
        }
      </nav>
      <div class="flex items-center gap-2">
        <Search />
        <Button
          isLink
          size="xs"
          variant="default"
          href="/contact"
          class="hidden lg:flex"
        >
          Get My AI Audit
        </Button>
        <MobileNav links={navLinks} />
      </div>
    </div>
  </Wrapper>
  <div class="group/megamenu">
    <MegaMenu />
  </div>
</header>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function() {
    const header = document.querySelector("header");
    if (!header) return;

    const servicesLink = header.querySelector('a[href="/ai-services"]');
    const industriesLink = header.querySelector('a[href="/industries"]');
    const resourcesLink = header.querySelector('a[href="#"]');
    const megamenu = header.querySelector("#megamenu");
    const resourcesMegamenu = header.querySelector("#resources-megamenu");

    console.log("Navigation script loaded");
    console.log("Header:", header);

    const hideAllMenus = () => {
      megamenu?.classList.add("hidden");
      megamenu?.classList.remove("block");
      resourcesMegamenu?.classList.add("hidden");
      resourcesMegamenu?.classList.remove("block");
    };

    const showMenu = (menu) => {
      hideAllMenus();
      menu?.classList.remove("hidden");
      menu?.classList.add("block");
    };

    // Services and Industries links
    [servicesLink, industriesLink].forEach((link) => {
      if (!link) return;
      link.addEventListener("mouseenter", () => showMenu(megamenu));
      link.addEventListener("mouseleave", () => hideAllMenus());
    });

    // Resources link
    if (resourcesLink) {
      resourcesLink.addEventListener("click", (e) => {
        e.preventDefault();
      });
      resourcesLink.addEventListener("mouseenter", () => showMenu(resourcesMegamenu));
      resourcesLink.addEventListener("mouseleave", () => hideAllMenus());
    }

    // Megamenu hover states
    megamenu?.addEventListener("mouseenter", () => megamenu?.classList.remove("hidden"));
    megamenu?.addEventListener("mouseleave", () => hideAllMenus());

    resourcesMegamenu?.addEventListener("mouseenter", () => resourcesMegamenu?.classList.remove("hidden"));
    resourcesMegamenu?.addEventListener("mouseleave", () => hideAllMenus());
  });
</script>
