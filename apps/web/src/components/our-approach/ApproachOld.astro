---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";

import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const paths = [
  {
    title: "Path 1: Strategy Theater",
    description:
      "Beautiful slide decks. Impressive frameworks. Zero execution plan. You're left holding a $50K strategy document that your team can't implement because it assumes resources you don't have, readiness you haven't built, and cultural buy-in that doesn't exist.",
  },
  {
    title: "Path 2: Tool-First Chaos",
    description:
      "Vendors sell you their platform. Consultants deploy it. Three months later, adoption is 12%, ROI is negative, and your team resents the \"AI initiative\" they were never prepared for.",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-12">
    <div class="p-8 lg:p-12 bg-base-50">
      <div class="w-3/4">
        <Text
          tag="h2"
          variant="displayMD"
          class="text-base-900 text-balance font-display"
        >
The Problem With Most "AI Strategy"
        </Text>
        <Text
          tag="p"
          variant="textBase"
          class="text-base-700 lg:text-pretty lg:col-span-2 mt-4"
        >
You've sat through the vendor demos. Nodded through the conference keynotes. Downloaded the white papers promising transformation. And you're still stuck asking: "Where do we actually start?"

        </Text>
      </div>

      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-8 mt-12"
      >
        {
          paths.map((path) => (
            <div class="relative group bg-white flex flex-col overflow-hidden p-8 gap-24 lg:gap-62 h-full justify-between">
              <div>
                <Text
                  tag="h3"
                  variant="textXL"
                  class="mb-4 text-base-900 font-semibold"
                >
                  {path.title}
                </Text>
                <Text
                  tag="p"
                  variant="textBase"
                  class="text-base-600 mt-4 text-pretty"
                >
                  {path.description}
                </Text>
              </div>
            </div>
          ))
        }
      </div>

      <div class="mt-12">
        <Text
          tag="h2"
          variant="displayMD"
          class="text-base-900 text-balance font-display"
        >
          We reject both paths.
        </Text>
      </div>
    </div>
  </Wrapper>
</section>
