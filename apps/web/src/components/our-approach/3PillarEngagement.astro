---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Button from "@/components/fundations/elements/Button.astro";

const pillars = [
  {
    title: "We Advise",
    subtitle: "Independent Strategic Counsel",
    sections: {
      whatItIs: "Ongoing strategic guidance for executives making frequent, high-stakes AI decisions—vendor selection, budget allocation, governance design, stakeholder alignment.",
      howWeDeliver: [
        "Executive Advisory Retainer: Monthly/bi-weekly strategic counsel sessions",
        "Leadership AI Fluency Cohort: 8-week training for 6-12 leaders",
        "Board & Executive Briefings: Private strategic sessions for governance"
      ],
      whoThisServes: "CEOs, CFOs, COOs making 3+ AI decisions per quarter—especially in law firms, healthcare, nonprofits, retail, and African enterprises."
    },
    bgColor: "#E65100",
  },
  {
    title: "We Implement",
    subtitle: "Build Systems That Work",
    sections: {
      whatItIs: "Specialized AI automation, agentic workflows, and integration projects designed and deployed inside your environment—so you own and control them.",
      howWeDeliver: [
        "Discovery & Assessment: 2-4 week technical mapping and scoping",
        "Implementation: Custom automation and agentic systems in your infrastructure",
        "Workshops & Training: Hands-on skill-building for your team"
      ],
      whoThisServes: "Operations leaders, CTOs, process owners who need AI systems deployed—not just discussed."
    },
    bgColor: "#FFB300",
  },
  {
    title: "We Partner",
    subtitle: "Maintain & Optimize Over Time",
    sections: {
      whatItIs: "Ongoing retainer partnership maintaining, updating, and expanding your automation ecosystem after go-live.",
      howWeDeliver: [
        "Ongoing Support: Monitoring, maintenance, troubleshooting",
        "Expansion Planning: Identify and implement new opportunities",
        "Strategic Evolution: Model upgrades and architectural improvements"
      ],
      whoThisServes: "Organizations viewing AI adoption as a journey, not a one-time project—teams that want systems that improve over time."
    },
    bgColor: "bg-accent-700",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-12">
    <div class="mb-12 max-w-2xl">
      <Text
        tag="h2"
        variant="displayMD"
        class="text-base-900 text-balance font-display"
      >
        Our 3 Pillar Engagement Model
      </Text>
      <Text
        tag="p"
        variant="textBase"
        class="text-base-700 mt-4"
      >
        Every engagement—whether advisory, implementation, or ongoing partnership—starts with the Human-Centric AI Integration Framework (HCAIF). We assess organizational readiness across 7 dimensions before recommending technology.
      </Text>
    </div>

    <div class="flex flex-col lg:flex-row gap-0 rounded-lg overflow-hidden">
      {
        pillars.map((pillar) => (
          <div class={`flex-1 p-8 lg:p-12 flex flex-col justify-between text-white ${pillar.bgColor.startsWith('#') ? '' : pillar.bgColor}`} style={pillar.bgColor.startsWith('#') ? `background-color: ${pillar.bgColor}` : ''}>
            {pillar.sections ? (
              <div class="text-left">
                <Text
                  tag="h3"
                  variant="textXL"
                  class="text-white font-semibold mb-2"
                >
                  {pillar.title}
                </Text>
                <Text
                  tag="p"
                  variant="textSM"
                  class="text-white/80 mb-6 italic"
                >
                  {pillar.subtitle}
                </Text>

                <div class="space-y-4">
                  <div>
                    <Text
                      tag="p"
                      variant="textXS"
                      class="text-white/70 uppercase font-semibold mb-2"
                    >
                      What It Is
                    </Text>
                    <Text
                      tag="p"
                      variant="textSM"
                      class="text-white/90"
                    >
                      {pillar.sections.whatItIs}
                    </Text>
                  </div>

                  <div>
                    <Text
                      tag="p"
                      variant="textXS"
                      class="text-white/70 uppercase font-semibold mb-2"
                    >
                      How We Deliver
                    </Text>
                    <ul class="space-y-1">
                      {pillar.sections.howWeDeliver.map((item) => (
                        <li class="text-sm text-white/90">• {item}</li>
                      ))}
                    </ul>
                  </div>

                  <div>
                    <Text
                      tag="p"
                      variant="textXS"
                      class="text-white/70 uppercase font-semibold mb-2"
                    >
                      Who This Serves
                    </Text>
                    <Text
                      tag="p"
                      variant="textSM"
                      class="text-white/90"
                    >
                      {pillar.sections.whoThisServes}
                    </Text>
                  </div>
                </div>
              </div>
            ) : (
              <div class="text-center">
                <Text
                  tag="h3"
                  variant="textXL"
                  class="text-white font-semibold mb-4"
                >
                  {pillar.title}
                </Text>
                <Text
                  tag="p"
                  variant="textBase"
                  class="text-white/90"
                >
                  {pillar.description}
                </Text>
              </div>
            )}
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
