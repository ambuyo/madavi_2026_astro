---
// Assets
import { Image } from "astro:assets";
import talk from "@/images/assets/talk.png";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const features = [
  {
    title: "Leadership Buy-In",
    description:
      "At least one C-level executive actively championing AI adoption, attending strategic sessions, and removing organizational blockers.",
  },
  {
    title: "Clear Problem Definition",
    description:
      "Specific pain points or opportunities identified (not just \"we should do AI\"). You know what you're trying to improve and why it matters.",
  },
  {
    title: "Realistic Timeline Expectations",
    description:
      "Understanding that cultural change takes months, not weeks. Adoption is a journey, not a one-time deployment.",
  },
  {
    title: "Team Capacity",
    description:
      "Someone internally accountable for coordinating with us, gathering requirements, testing systems, and driving adoption.",
  },
  {
    title: "Willingness to Experiment",
    description:
      "Comfort with iteration and learning. Pilot-first mindset rather than demanding perfect systems on day one.",
  },
  {
    title: "Budget Alignment",
    description:
      "Investment level matches ambition. Can't expect enterprise transformation on startup budget.",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-12">
    <div
      class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 p-8 lg:p-12 bg-base-50"
    >
      <div class="flex flex-col lg:col-span-2">
        <div>
          <Text
            tag="h2"
            variant="displayMD"
            class="text-base 950 text-balance font-medium tracking-tight font-display mt-8"
          >
What Makes An Engagement Successful?

          </Text>
          <Text
            tag="p"
            variant="textBase"
            class="text-base-700 mt-2 text-pretty"
          >
We've learned what predicts success across 50+ implementations:
          </Text>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-y-12 gap-x-8 mt-12">
          {
            features.map((feature) => (
              <div>
                <Text
                  tag="h3"
                  variant="textLG"
                  class="text-base-900 font-display"
                >
                  {feature.title}
                </Text>
                <Text
                  tag="p"
                  variant="textSM"
                  class="text-base-600 mt-2 text-pretty"
                >
                  {feature.description}
                </Text>
              </div>
            ))
          }
        </div>
      </div>
      <Image
        src={talk}
        alt="Image"
        width={800}
        height={1440}
        loading="eager"
        decoding="async"
        class="size-full object-cover object-center aspect-square"
      />
    </div>
  </Wrapper>
</section>
