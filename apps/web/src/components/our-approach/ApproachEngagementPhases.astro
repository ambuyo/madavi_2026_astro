---
// Assets
import { Image } from "astro:assets";
import methodologyImage from "@/images/assets/talk.png";
import testimonialImage from "@/images/assets/testimonial.png";

// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const methodologySteps = [ 
  {
    title: "Discovery Call",
    subtitle: "Free Discovery",
    description:
      "30-minute conversation to understand your goals before we talk solutions. No sales pitch. No vendor demo. Just clarity on whether engagement makes sense.",
    bulletLabel: "What Happens:",
    bulletPoints: [
      "We ask about your business, challenges, systems, and goals",
      "You ask about our approach, experience, and whether we fit",
      "We determine together what engagement type might work (if any)",
    ],
  },
  {
    title: "Paid Discovery & Assessment",
    subtitle: "2-4 Weeks",
    description:
      "Get clarity before you commit to implementation. We map your technical landscape, assess readiness, and document what's possible within your constraints.",
    bulletLabel: "Deliverable:",
    bulletPoints: [
      "Comprehensive assessment report with scope and dependencies",
      "Effort estimates and phased delivery roadmap",
      "Success metrics and investment requirements",
    ],
  },
  {
    title: "Implementation & Delivery",
    subtitle: "4-12 Weeks",
    description:
      "Build and deploy your systems inside your environment. Architecture, development, testing, documentation, and knowledge transfer—so your team owns what we build.",
    bulletLabel: "Outcome:",
    bulletPoints: [
      "Systems deployed and working in production",
      "Teams trained and confident in maintenance",
      "Documentation complete for troubleshooting",
      "Measurable results visible from day one",
    ],
  },
  {
    title: "Ongoing Partnership & Optimization",
    subtitle: "Continuous",
    description:
      "Ensure systems stay working, relevant, and improving over time. Monitoring, optimization, expansion planning, and strategic evolution as technology advances.",
    bulletLabel: "Structure:",
    bulletPoints: [
      "Monthly retainer with defined support hours",
      "Escalation protocols for urgent issues",
      "Quarterly strategic reviews and planning",
      "Flexible capacity scaling during high-intensity periods",
    ],
  },
];
---

<section>
  <Wrapper variant="paddingLess" class="py-24">
    <div class="grid grid-cols-1 lg:grid-cols-2">
      <div>
        <div class="relative w-full lg:sticky lg:top-16 lg:h-screen">
          <Image
            src={methodologyImage}
            width={1440}
            height={900}
            alt="Madavi - WHY Madavi Stands Out"
            class="object-cover object-center w-full h-full bg-base-50"
            loading="eager"
            decoding="async"
          />
          <div
            class="lg:absolute lg:inset-0 size-full flex flex-col items-start justify-start px-8 md:px-12 lg:px-24 z-10 py-24 text-white"
            style="background: linear-gradient(90deg, rgba(230, 81, 0, 0.3) 0%, rgba(255, 179, 0, 0.3) 100%);"
          >
            <div class="w-full">
              <Text
                tag="p"
                variant="textXS"
                class="text-accent-400 tracking-wide uppercase"
              >
HCAIF — Not Just a Framework, a Philosophy
              </Text>
              <Text
                tag="h2"
                variant="displayLG"
                class="text-white font-display text-balance mt-12"
              >
                How We Work
              </Text>
              <Text tag="p" variant="textSM" class="text-base-300 mt-2">
Our Human-Centric AI Integration Framework isn't theoretical—it's the battle-tested methodology we use to deploy AI across five industry verticals. It ensures every automation we build preserves the human elements that matter while eliminating the busywork that doesn't.
              </Text>
              <div
                class="mt-12 grid grid-cols-1 overflow-hidden lg:grid-cols-2 bg-white/5 backdrop-blur-sm"
              >
                <Image
                  src={testimonialImage}
                  width={500}
                  height={500}
                  loading="eager"
                  decoding="async"
                  alt="Client testimonial"
                  class="object-cover h-60 size-full object-top"
                />
                <figure class="p-4 flex flex-col h-full justify-between">
                  <blockquote>
                    <Text tag="p" variant="textSM" class="text-base-300 italic">
                      "Madavi transformed how we approach AI. Their strategic guidance and hands-on support gave us confidence to move forward. We've already seen significant improvements."
                    </Text>
                  </blockquote>
                  <figcaption class="mt-3 flex items-center gap-3">
                    <Text
                      tag="p"
                      variant="textXS"
                      class="text-accent-400 font-medium"
                    >
                      Sarah Chen, CTO,
                      <br />
                      Tech Innovations Inc.
                    </Text>
                  </figcaption>
                </figure>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="p-8 lg:p-20 bg-base-50">
        <dl class="flex flex-col gap-8">
          {
            methodologySteps.map((step, idx) => (
              <>
                <div class="bg-white p-8 flex flex-col items-start sticky top-8 lg:top-20">
                  <dt>
                    <Text
                      tag="p"
                      variant="displayXL"
                      class="text-accent-800 font-display italic font-medium"
                    >
                      {idx + 1}
                    </Text>
                    <Text
                      tag="h3"
                      variant="displaySM"
                      class="text-base-800 font-display mt-12"
                    >
                      {step.title}
                    </Text>
                    <Text
                      tag="p"
                      variant="textBase"
                      class="text-base-700 font-medium mt-4"
                    >
                      {step.subtitle}
                    </Text>
                  </dt>
                  <dd>
                    <Text
                      tag="p"
                      variant="textSM"
                      class="text-base-600 text-balance mt-4"
                    >
                      {step.description}
                    </Text>
                    {step.bulletPoints && (
                      <div class="mt-6">
                        {step.bulletLabel && (
                          <Text
                            tag="p"
                            variant="textSM"
                            class="text-base-700 font-semibold mb-3"
                          >
                            {step.bulletLabel}
                          </Text>
                        )}
                        <ul class="space-y-2">
                          {step.bulletPoints.map((point) => (
                            <li class="flex items-start gap-2">
                              <span class="text-accent-600 font-bold mt-1">•</span>
                              <Text
                                tag="span"
                                variant="textSM"
                                class="text-base-600"
                              >
                                {point}
                              </Text>
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}
                  </dd>
                </div>
              </>
            ))
          }
        </dl>

      </div>
    </div>
  </Wrapper>
</section>
