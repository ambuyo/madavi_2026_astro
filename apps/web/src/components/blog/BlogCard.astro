---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
// Content
const { title, url, image, category } = {
  url: "/" + Astro.props.post.slug,
  title: Astro.props.post.data.title,
  image: Astro.props.post.data.image.url,
  category: Astro.props.post.data.categories?.[0],
};

// Convert title to proper sentence case
const sentenceCaseTitle = title
  .split(" ")
  .map((word, index) => {
    if (index === 0) {
      // Capitalize first word
      return word.charAt(0).toUpperCase() + word.slice(1).toLowerCase();
    }
    // Lowercase rest, but preserve acronyms (all caps words stay caps)
    return word.length > 1 && word === word.toUpperCase()
      ? word
      : word.toLowerCase();
  })
  .join(" ");
---

<article
  class="relative group bg-sky-100 rounded-2xl flex flex-col overflow-hidden h-full justify-between p-8 lg:p-10 gap-8"
>
  <a
    href={url}
    title={`Read more: ${title}`}
    aria-label={`Read blog post: ${title}`}
    class="absolute inset-0 z-10"></a>

  <div class="flex-1">
    {category && (
      <a
        href={`/blog/cat/${category.slug}`}
        class="inline-block relative z-20 mb-2"
        onClick={(e) => e.stopPropagation()}
      >
        <Text
          tag="p"
          variant="textSM"
          class="text-base-600 hover:text-accent-600 transition-colors capitalize"
        >
          {category.name}
        </Text>
      </a>
    )}
    <Text tag="h3" variant="textLG" class="text-base-900 font-semibold text-left"
      >{sentenceCaseTitle}</Text
    >
  </div>

  {image && (
    <div class="relative w-full h-32 lg:h-40 overflow-hidden rounded-lg">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
    </div>
  )}
</article>
