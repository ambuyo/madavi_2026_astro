---
// LLM Crawler Analytics - Track AI bot interactions
// Logs LLM crawler visits, content access patterns, and API usage
---

<script>
  // Detect LLM crawlers from User-Agent
  const llmCrawlers = {
    "GPTBot": "OpenAI",
    "Claude-Web": "Anthropic",
    "PerplexityBot": "Perplexity AI",
    "YouBot": "You.com",
    "Google-Extended": "Google AI",
    "CCBot": "Common Crawl",
  };

  function detectLLMCrawler() {
    const ua = navigator.userAgent;
    for (const [botName, company] of Object.entries(llmCrawlers)) {
      if (ua.includes(botName)) {
        return { botName, company };
      }
    }
    return null;
  }

  function logLLMVisit() {
    const crawler = detectLLMCrawler();
    if (!crawler) return;

    const visitData = {
      timestamp: new Date().toISOString(),
      crawler: crawler.botName,
      company: crawler.company,
      url: window.location.href,
      path: window.location.pathname,
      userAgent: navigator.userAgent,
      referrer: document.referrer,
    };

    // Send to analytics endpoint (create a server-side logging endpoint)
    fetch("/api/analytics/llm-visit", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(visitData),
    }).catch(() => {
      // Silently fail - don't block page load
    });

    // Log to browser console for debugging
    console.info(
      `%cLLM Crawler Detected: ${crawler.botName} (${crawler.company})`,
      "color: #3498db; font-weight: bold;"
    );
  }

  function trackAPIAccess() {
    // Track API endpoint access for LLM crawlers
    if (!detectLLMCrawler()) return;

    const originalFetch = window.fetch;
    window.fetch = function(...args) {
      const [resource] = args;
      const url = typeof resource === "string" ? resource : resource?.url;

      if (url && (url.includes("/api/") || url.includes("/llm-"))) {
        fetch("/api/analytics/api-access", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            timestamp: new Date().toISOString(),
            endpoint: url,
            crawler: detectLLMCrawler(),
          }),
        }).catch(() => {});
      }

      return originalFetch.apply(this, args);
    };
  }

  // Initialize LLM analytics
  function initLLMAnalytics() {
    // Log initial visit
    logLLMVisit();

    // Track API access
    trackAPIAccess();

    // Track page transitions for SPAs
    document.addEventListener("astro:page-load", () => {
      logLLMVisit();
    });
  }

  // Run after page load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initLLMAnalytics);
  } else {
    initLLMAnalytics();
  }

  // Make tracking function available globally
  window.logLLMAccess = (eventType, data) => {
    const crawler = detectLLMCrawler();
    if (crawler) {
      fetch("/api/analytics/llm-event", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          timestamp: new Date().toISOString(),
          eventType,
          crawler,
          data,
        }),
      }).catch(() => {});
    }
  };
</script>
