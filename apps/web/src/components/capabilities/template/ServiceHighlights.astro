---
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import ServiceCard from "./ServiceCard.astro";
import TeamCard from "@/components/team/TeamCard.astro";
import CasesCard from "@/components/cases/CasesCard.astro";
import { getCollection } from "astro:content";

interface Props {
  type: "practices" | "team" | "cases";
}

const { type } = Astro.props;

let items: any[] = [];
let config = {
  label: "",
  heading: "",
  description: "",
  ctaText: "",
  ctaHref: "",
  altCtaText: "",
  altCtaHref: "",
  showAltCta: false,
};

if (type === "practices") {
  items = await getCollection("services");
  config = {
    label: "Areas of Expertise",
    heading: "Practice Areas",
    description:
      "Our experienced attorneys provide comprehensive legal services across a wide range of practice areas, delivering strategic solutions tailored to your unique needs.",
    ctaText: "View all practice areas",
    ctaHref: "/services",
    altCtaText: "Free Consultation",
    altCtaHref: "/contact",
    showAltCta: true,
  };
} else if (type === "team") {
  items = await getCollection("team");
  config = {
    label: "The team",
    heading: "Our Team",
    description:
      "Meet our experienced attorneys who are dedicated to providing exceptional legal representation and building lasting relationships with our clients.",
    ctaText: "Meet all attorneys",
    ctaHref: "/team",
    altCtaText: "Careers",
    altCtaHref: "/careers",
    showAltCta: true,
  };
} else if (type === "cases") {
  items = await getCollection("caseStudies");
  config = {
    label: "Stories",
    heading: "Case Studies",
    description:
      "Explore our successful case outcomes and see how we've helped clients achieve their legal objectives across various practice areas and industries.",
    ctaText: "View all cases",
    ctaHref: "/our-work",
    altCtaText: "",
    altCtaHref: "",
    showAltCta: false,
  };
}

const highlightedItems = items.slice(0, 2);
const itemCount = items.length;
const bgClass = type === "cases" ? "bg-base-50" : "bg-white";
const alternateBg = type === "cases" ? "bg-white" : "bg-base-50";
---

<section class={bgClass}>
  <Wrapper variant="standard" class="py-24">
    <div class="grid grid-cols-1 lg:grid-cols-4 items-start gap-y-8">
      <Text
        tag="p"
        variant="textXS"
        class="text-secondary-500 tracking-wide uppercase"
      >
        {config.label}
      </Text>
      <div class="lg:col-span-3">
        <Text
          tag="h2"
          variant="displayLG"
          class="text-accent-800 font-display text-balance"
        >
          {config.heading}
        </Text>
        <Text tag="p" variant="textLG" class="text-base-600 mt-4">
          {config.description}
        </Text>
      </div>
    </div>

    {
      highlightedItems.length > 0 && (
        <div class="grid grid-cols-1 lg:grid-cols-2 mt-12 lg:mt-24 gap-8">
          {highlightedItems.map((item) => {
            if (type === "practices") {
              return <ServiceCard service={item} />;
            } else if (type === "team") {
              return <TeamCard post={item} />;
            } else if (type === "cases") {
              return <CasesCard post={item} />;
            }
          })}
        </div>
      )
    }

    <div class={`${alternateBg} p-8 lg:p-12 mt-8`}>
      <div
        class="flex flex-col lg:flex-row items-start lg:items-center justify-between gap-6"
      >
        <div>
          <Text
            tag="h3"
            variant="displaySM"
            class="text-accent-800 font-display"
          >
            Explore all {config.heading.toLowerCase()}
          </Text>
          <Text tag="p" variant="textSM" class="text-base-600 mt-1">
            {type === "practices" &&
              `Browse our ${itemCount}+ areas of expertise or talk with us to find the right fit.`}
            {type === "team" &&
              `Get to know our ${itemCount}+ attorneys and their areas of focus.`}
            {type === "cases" &&
              `Dive into ${itemCount}+ detailed results and outcomes.`}
          </Text>
        </div>
        <div class="flex flex-col lg:flex-row w-full lg:w-fit items-center gap-2">
          <Button
            isLink={true}
            href={config.ctaHref}
            variant="default"
            size="sm"
            class="w-full lg:w-fit"
          >
            {config.ctaText}
          </Button>
          {config.showAltCta && (
            <Button
              isLink={true}
              href={config.altCtaHref}
              variant="muted"
              size="sm"
              class="w-full lg:w-fit"
            >
              {config.altCtaText}
            </Button>
          )}
        </div>
      </div>
    </div>
  </Wrapper>
</section>
