---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Button from "@/components/fundations/elements/Button.astro";

---

<section>
  <Wrapper variant="paddingLess">
    <div class="relative overflow-hidden">
      <video
        autoplay
        muted
        loop
        playsinline
        class="object-cover object-center w-full h-[60dvh] lg:h-[72dvh] bg-base-50"
      >
        <source src="/services/bgvideo2.mp4" type="video/mp4" />
      </video>
      <div
        aria-hidden="true"
        class="absolute inset-0 pointer-events-none bg-accent-950/70"
      >
      </div>
    </div>
  </Wrapper>
  <Wrapper variant="standard" class="py-12">
    <div class="grid grid-cols-1 lg:grid-cols-4 items-start gap-y-8">
      <Text
        tag="p"
        variant="textXS"
        class="text-secondary-500 tracking-wide uppercase"
      >
AI CAPABILITIES
      </Text>
      <div class="lg:col-span-3">
        <Text
          tag="h2"
          variant="displayLG"
          class="text-accent-800 font-display text-balance"
        >
        AI Readiness Audit
        </Text>
        <Text tag="p" variant="textLG" class="text-base-600 mt-4">
60% of businesses waste $50K+ on AI tools they're not ready to use. Get a free AI readiness audit to find out if you're ready— <br/><br/><span class="text-accent-600">before you invest. No obligation. </span>       </Text>
       <Text tag="p" variant="textLG" class="text-base-600 mt-4">
      Not a sales call. Not a product demo. Not a generic questionnaire.
        </Text>
                  <Text tag="p" variant="textLG" class="text-base-600 mt-4">
A real assessment with honest findings. If you're ready, we tell you what to build. If you're not, we tell you what needs to change first.
        </Text>
      </div>
    </div>
  </Wrapper>
  
</section>
