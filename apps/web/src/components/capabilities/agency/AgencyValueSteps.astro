---
// Assets
import Kicker from "@/components/fundations/elements/Kicker.astro";
import { Image } from "astro:assets";
import heroImage from "@/images/assets/heroImage.png";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

interface Props {
  steps?: Array<{
    phase: string;
    title: string;
    description: string;
    bullets: string[];
  }>;
}

const { steps } = Astro.props;

const defaultSteps = [
  {
    phase: "Pre-Program (Week 0)",
    title: "Cohort Formation & Baseline",
    description: "Match leaders with compatible peers and establish starting point",
    bullets: [
      "Leadership AI literacy baseline assessment",
      "Cohort matching (by industry, role, or maturity level)",
      "Pre-program orientation session",
      "Learning objectives and success criteria definition",
      "Access to cohort portal and materials"
    ]
  },
  {
    phase: "Core Program (Weeks 1-8)",
    title: "Weekly Learning Sessions",
    description: "Structured curriculum with peer learning and practical application",
    bullets: [
      "90-minute weekly sessions (live virtual or in-person)",
      "Pre-session assignments and case studies",
      "Peer discussion and experience sharing",
      "Practical exercises on real organizational challenges",
      "Guest practitioners and vendor Q&As (no sales pitches)"
    ]
  },
  {
    phase: "Post-Program (Ongoing)",
    title: "Alumni Network & Resources",
    description: "Continued access to cohort network and updated materials",
    bullets: [
      "Quarterly alumni sessions (trends, new tools, challenges)",
      "Cohort Slack/WhatsApp channel for ongoing questions",
      "Resource library updates (frameworks, vendor comparisons)",
      "Priority access to future cohorts and workshops",
      "Alumni-only office hours with program facilitators"
    ]
  }
];

const displaySteps = steps && steps.length > 0 ? steps : defaultSteps;
---

<section>
  <Wrapper variant="standard" class="py-8">
    <div class="p-8 lg:p-12 bg-green-50">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-4 md:items-end">
        <div>
            <Text
                    tag="h3"
                    variant="displaySM"
                    class="text-base-800 font-display mt-12"
                  >
What You Get
                  </Text>
        </div>
        <Text
          tag="p"
          variant="textLG"
          class="mt-4 text-base-600 lg:text-balance md:col-span-2 md:col-start-3"
        >
          The 60-minute diagnostic doesn't end with recommendations. You'll walk away with a clear action plan.
        </Text>
      </div>
      <div class="items-center mt-12 grid grid-cols-1 gap-y-4 lg:grid-cols-2">
        <div class="flex flex-col overflow-x-auto gap-8 md:overflow-x-visible">
          <button
            class="w-full text-left cursor-pointer tab-btn transition-all duration-300"
            data-tab="feature1"
          >
            <div class="hidden md:block">
               <Text tag="h2" variant="textSM" class="text-base-700 mt-2">
During the 60-Minute Session                    </Text>
              <Text tag="h3" variant="textLG" class="font-medium text-green-900">
Real-Time Diagnostic

              </Text>
              <Text
                tag="p"
                variant="textBase"
                class="mt-4 text-green-800 text-balance"
              >
                <ul class="list-disc list-inside space-y-1">
                  <li>Structured interview covering all 7 dimensions</li>
                  <li>Real-time pattern identification</li>
                  <li>Preliminary findings discussion</li>
                  <li>Blocker identification</li>
                  <li>Initial recommendations</li>
                </ul>
              </Text>
            </div>
          </button>
          <button
            class="w-full text-left cursor-pointer tab-btn transition-all duration-300"
            data-tab="feature2"
          >
            <div class="hidden md:block">

            <Text tag="h2" variant="textSM" class="text-base-700 mt-2">
Within 3 Business Days : Detailed Audit Report (15-25 pages)                  </Text>
             <Text tag="h3" variant="textLG" class="font-medium text-green-900">
Section 1: Readiness Score


              </Text>
            <Text
                tag="p"
                variant="textBase"
                class="mt-4 text-green-800 text-balance"
              >
                <ul class="list-disc list-inside space-y-1">
                  <li>Overall readiness rating (1-10 scale)</li>
                  <li>Dimension-by-dimension breakdown</li>
                  <li>Red flags and green lights</li>
                  <li>Comparison to similar organizations</li>
                </ul>
              </Text>
            </div>
          </button>
          <button
            class="w-full text-left cursor-pointer tab-btn transition-all duration-300"
            data-tab="feature3"
          >
            <div class="hidden md:block">
             <Text tag="h4" variant="textLG" class="font-medium text-green-900">
Section 2: Gap Analysis
              </Text>
            <Text
                tag="p"
                variant="textBase"
                class="mt-4 text-green-800 text-balance"
              >
                <ul class="list-disc list-inside space-y-1">
                  <li>What's blocking AI adoption</li>
                  <li>Cultural barriers to address</li>
                  <li>Process improvements needed</li>
                  <li>Infrastructure upgrades required</li>
                  <li>Resource constraints to solve</li>

                </ul>
              </Text>
            </div>
          </button>
          <button
            class="w-full text-left cursor-pointer tab-btn transition-all duration-300"
            data-tab="feature4"
          >
            <div class="hidden md:block">
   <Text tag="h4" variant="textLG" class="font-medium text-green-900">
Section 3: Opportunity Mapping
              </Text>
            <Text
                tag="p"
                variant="textBase"
                class="mt-4 text-green-800 text-balance"
              >
                <ul class="list-disc list-inside space-y-1">
                  <li>Highest-impact automation candidates</li>
                  <li>Quick wins (easy + high value)</li>
                  <li>Strategic bets (hard + transformative)</li>
                  <li>No-go zones (not ready, too risky)</li>

                </ul>
              </Text>
            </div>
          </button>
                    <button
            class="w-full text-left cursor-pointer tab-btn transition-all duration-300"
            data-tab="feature5"
          >
            <div class="hidden md:block">
   <Text tag="h4" variant="textLG" class="font-medium text-green-900">
Section 4: Recommendations              </Text>
            <Text
                tag="p"
                variant="textBase"
                class="mt-4 text-green-800 text-balance"
              >
                <ul class="list-disc list-inside space-y-1">
                  <li>If ready: What to build first</li>
                  <li>If not ready: What to fix first</li>
                  <li>Estimated timeline to readiness</li>
                  <li>Budget guidance</li>
                  <li>Next steps</li>
                </ul>
              </Text>
            </div>
          </button>
        </div>
        <div class="relative flex-1 aspect-square">
          <Image
            src={heroImage}
            alt="Features showcase"
            width={600}
            height={800}
            loading="eager"
            decoding="async"
            class="absolute inset-0 object-cover object-center w-full h-full"
          />

          <div
            class="absolute inset-0 z-10 flex items-center justify-center p-4 bg-black/20"
          >
            <div class="tab-content" id="feature1">
              <div class="w-full max-w-sm mx-auto p-6 bg-white rounded-lg shadow-lg">
                <p class="text-sm font-medium text-green-800">Workflow Widget</p>
                <p class="text-xs text-gray-600 mt-2">Coming soon</p>
              </div>
            </div>
            <div class="hidden tab-content" id="feature2">
              <div class="w-full max-w-xl p-6 bg-white rounded-lg shadow-lg">
                <p class="text-sm font-medium text-green-800">Calendar Widget</p>
                <p class="text-xs text-gray-600 mt-2">Coming soon</p>
              </div>
            </div>
            <div class="hidden tab-content" id="feature3">
              <div class="w-full p-6 bg-white rounded-lg shadow-lg">
                <p class="text-sm font-medium text-green-800">Analytics Widget</p>
                <p class="text-xs text-gray-600 mt-2">Coming soon</p>
              </div>
            </div>
            <div class="hidden tab-content" id="feature4">
              <div class="w-full p-6 bg-white rounded-lg shadow-lg">
                <p class="text-sm font-medium text-green-800">Boards Widget</p>
                <p class="text-xs text-gray-600 mt-2">Coming soon</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Wrapper>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const tabButtons = document.querySelectorAll(".tab-btn");
    const tabContents = document.querySelectorAll(".tab-content");

    // Activate selected tab and deactivate others
    const setActiveTab = (tabId) => {
      tabButtons.forEach((btn) => {
        const isActive = btn.getAttribute("data-tab") === tabId;
        btn.classList.toggle("active", isActive);
        btn.classList.toggle("opacity-100", isActive);
        btn.classList.toggle("text-base-800", isActive);
        btn.classList.toggle("opacity-50", !isActive);
        btn.classList.toggle("text-base-600", !isActive);
      });

      tabContents.forEach((content) => {
        content.classList.toggle("hidden", content.id !== tabId);
      });
    };

    // Attach event listeners to each tab button
    tabButtons.forEach((button) =>
      button.addEventListener("click", () =>
        setActiveTab(button.getAttribute("data-tab"))
      )
    );

    // Activate the first tab on load
    setActiveTab("feature1");

    // Animate feature blocks when they enter the viewport
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("opacity-100", "translate-y-0");
            entry.target.classList.remove("opacity-0", "translate-y-8");
            entry.target.style.transition = "all 0.5s ease-out";
          }
        });
      },
      { threshold: 0.1 }
    );

    // Start observing all feature blocks
    document
      .querySelectorAll('[id^="feature"]')
      .forEach((block) => observer.observe(block));
  });
</script>
