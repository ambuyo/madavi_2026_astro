---
// Fundations
import Button from "@/components/fundations/elements/Button.astro";
---

<form action="/api/contact" method="POST" class="space-y-6 bg-black p-8">
  <div>
    <label for="name" class="block text-sm font-medium text-base-300 mb-2">
      Full Name *
    </label>
    <input
      type="text"
      id="name"
      name="name"
      required
      class="w-full px-4 py-3 border-b border-base-800 placeholder-base-400 text-white border-x-0 border-t-0 focus:ring-0 focus:outline-none focus:border-base-800 transition-colors bg-white/5 focus:bg-white/10"
      placeholder="Your full name"
    />
  </div>
  <div>
    <label for="email" class="block text-sm font-medium text-base-300 mb-2">
      Email Address *
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      class="w-full px-4 py-3 border-b border-base-800 placeholder-base-400 text-white border-x-0 border-t-0 focus:ring-0 focus:outline-none focus:border-base-800 transition-colors bg-white/5 focus:bg-white/10"
      placeholder="your.email@example.com"
    />
  </div>
  <div>
    <label for="phone" class="block text-sm font-medium text-base-300 mb-2">
      Phone Number
    </label>
    <input
      type="tel"
      id="phone"
      name="phone"
      class="w-full px-4 py-3 border-b border-base-800 placeholder-base-400 text-white border-x-0 border-t-0 focus:ring-0 focus:outline-none focus:border-base-800 transition-colors bg-white/5 focus:bg-white/10"
      placeholder="(555) 123-4567"
    />
  </div>
  <div>
    <label for="company" class="block text-sm font-medium text-base-300 mb-2">
      Company Name
    </label>
    <input
      type="text"
      id="company"
      name="company"
      class="w-full px-4 py-3 border-b border-base-800 placeholder-base-400 text-white border-x-0 border-t-0 focus:ring-0 focus:outline-none focus:border-base-800 transition-colors bg-white/5 focus:bg-white/10"
      placeholder="Your company name"
    />
  </div>
  <div>
    <label for="service" class="block text-sm font-medium text-base-300 mb-2">
      Service Interested In
    </label>
    <select
      id="service"
      name="service"
      class="w-full px-4 py-3 border-b border-base-800 placeholder-base-400 text-white border-x-0 border-t-0 focus:ring-0 focus:outline-none focus:border-base-800 transition-colors bg-white/5 focus:bg-white/10"
    >
      <option value="">Select a service</option>
      <option value="bookkeeping">Bookkeeping Services</option>
      <option value="tax-preparation">Tax Preparation</option>
      <option value="financial-planning">Financial Planning</option>
      <option value="business-formation">Business Formation</option>
      <option value="cfo-services">CFO Services</option>
      <option value="audit-support">Audit Support</option>
      <option value="payroll">Payroll Services</option>
      <option value="consultation">Free Consultation</option>
      <option value="other">Other</option>
    </select>
  </div>
  <div>
    <label for="subject" class="block text-sm font-medium text-base-300 mb-2">
      Subject *
    </label>
    <input
      type="text"
      id="subject"
      name="subject"
      required
      class="w-full px-4 py-3 border-b border-base-800 placeholder-base-400 text-white border-x-0 border-t-0 focus:ring-0 focus:outline-none focus:border-base-800 transition-colors bg-white/5 focus:bg-white/10"
      placeholder="Brief description of your inquiry"
    />
  </div>
  <div>
    <label for="message" class="block text-sm font-medium text-base-300 mb-2">
      Message *
    </label>
    <textarea
      id="message"
      name="message"
      rows="6"
      required
      class="w-full px-4 py-3 border-b border-base-800 placeholder-base-400 text-white border-x-0 border-t-0 focus:ring-0 focus:outline-none focus:border-base-800 transition-colors bg-white/5 focus:bg-white/10 resize-vertical"
      placeholder="Please provide details about your accounting needs..."
    ></textarea>
  </div>
  <div class="flex items-start gap-3">
    <input
      type="checkbox"
      id="privacy"
      name="privacy"
      required
      class="mt-1 h-4 w-4 text-accent-600 focus:ring-accent-500 border-base-300 rounded"
    />
    <label for="privacy" class="text-sm text-base-600">
      I agree to the <a
        href="/legal/privacy"
        class="text-accent-600 hover:text-accent-700 underline"
        >Privacy Policy</a
      >
      and consent to being contacted regarding my inquiry.
    </label>
  </div>
  <Button variant="default" size="lg" type="submit" class="w-full">
    Send Message
  </Button>
</form>
