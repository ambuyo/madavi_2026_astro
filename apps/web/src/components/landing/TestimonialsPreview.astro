---
// Assets
import { Image } from "astro:assets";
import testimonial from "@/images/assets/testimonial.png";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import TestimonialCard1 from "@/components/testimonials/TestimonialCard.astro";
---

<section>
  <Wrapper variant="standard" class="py-12 lg:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-start">
      <Kicker variant="default">Client Testimonials</Kicker>
      <Text
        tag="h2"
        variant="displayMD"
        class="text-base-900 text-balance font-medium tracking-tight font-display lg:col-span-2 lg:-mt-2"
      >
        What Our Clients Say About Mulberry
      </Text>
      <div class="lg:col-span-2">
        <Text tag="p" variant="textLG" class="text-base-900 lg:text-pretty">
          Don't just take our word for it. Hear directly from the business
          owners and executives who've experienced the Mulberry difference
          firsthand.
        </Text>
        <Text
          tag="p"
          variant="textSM"
          class="text-base-600 mt-4 lg:text-pretty"
        >
          From improved financial clarity to significant tax savings, our
          clients share their experiences working with our certified accounting
          team and the real impact on their business success.
        </Text>
        <a
          href="/testimonials"
          class="uppercase font-medium flex text-base-900 group-hover:text-accent-400 mt-8"
        >
          Read all testimonials</a
        >
      </div>
    </div>
    <article
      class="relative group bg-base-50 grid grid-cols-1 lg:grid-cols-3 gap-4 mt-12 lg:mt-24"
    >
      <Image
        src={testimonial}
        alt="Image"
        width={800}
        height={600}
        loading="eager"
        decoding="async"
        class="object-cover object-center w-full aspect-square"
      />
      <div class="lg:col-span-2 p-8 grid grid-cols-1 gap-8 lg:grid-cols-3">
        <div class="flex flex-col h-full justify-between lg:col-span-2 gap-8">
          <blockquote>
            <Text
              tag="p"
              variant="textLG"
              class="text-base-900 font-medium leading-relaxed"
            >
              "Mulberry transformed our financial operations completely. Their
              expertise in tax planning saved us thousands, and their
              bookkeeping accuracy gave us confidence in our financial reports.
              Truly professional and reliable partners."
            </Text>
          </blockquote>
          <div>
            <Text tag="p" variant="textXL" class="text-base-900 font-display">
              Shaun Smith
            </Text>
            <Text tag="p" variant="textSM" class="text-base-600 mt-1">
              CEO, Tribeca
            </Text>
          </div>
        </div>
        <div
          class="lg:border-l lg:pl-8 flex flex-col h-full border-base-100 order-first lg:order-none"
        >
          <Text
            tag="p"
            variant="displayXL"
            class="text-base-900 font-display mt-auto"
          >
            100%
          </Text>
          <div class="pt-4 mt-4 border-t border-base-100">
            <Text tag="h3" variant="textBase" class="text-base-900 font-medium">
              Match rate.
            </Text>
          </div>
        </div>
      </div>
    </article>
  </Wrapper>
</section>
