---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

interface Report {
  title: string;
  description: string;
  category: string;
  imageUrl: string;
  href: string;
}

const reports: Report[] = [
  {
    title: "AI Readiness Index 2024",
    description: "Comprehensive analysis of organizational AI adoption barriers and opportunities across enterprise sectors.",
    category: "Research",
    imageUrl: "https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&h=400&fit=crop",
    href: "/reports/ai-readiness-2024",
  },
  {
    title: "Digital Transformation ROI Report",
    description: "Executive guide to measuring and maximizing return on digital transformation investments.",
    category: "Strategy",
    imageUrl: "https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=600&h=400&fit=crop",
    href: "/reports/digital-transformation-roi",
  },
  {
    title: "AI in Enterprise: Implementation Guide",
    description: "Best practices and lessons learned from implementing AI solutions in Fortune 500 organizations.",
    category: "Implementation",
    imageUrl: "https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=600&h=400&fit=crop",
    href: "/reports/ai-implementation-guide",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-12">
    <div class="space-y-12">
      <div class="max-w-2xl">
        <Kicker variant="default">Latest Reports</Kicker>
        <Text
          tag="h2"
          variant="displayMD"
          class="text-base-900 text-balance font-display lg:mt-8"
        >
          Research & Insights
        </Text>
        <Text
          tag="p"
          variant="textBase"
          class="text-base-700 lg:text-pretty mt-4"
        >
          Access our latest research reports on AI adoption, digital transformation, and organizational readiness. Get the insights you need to make informed decisions.
        </Text>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {
          reports.map((report) => (
            <a
              href={report.href}
              class="group flex flex-col h-full rounded-xl overflow-hidden border border-base-200 hover:border-accent-400 transition-colors bg-white hover:shadow-lg"
            >
              <div class="relative h-48 overflow-hidden bg-base-100">
                <img
                  src={report.imageUrl}
                  alt={report.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
              <div class="flex flex-col flex-grow p-6">
                <Text
                  tag="p"
                  variant="textXS"
                  class="text-accent-600 font-medium uppercase tracking-wide mb-2"
                >
                  {report.category}
                </Text>
                <Text
                  tag="h3"
                  variant="displaySM"
                  class="text-base-900 font-display mb-3 group-hover:text-accent-600 transition-colors"
                >
                  {report.title}
                </Text>
                <Text
                  tag="p"
                  variant="textBase"
                  class="text-base-600 flex-grow mb-4"
                >
                  {report.description}
                </Text>
                <Button
                  size="sm"
                  variant="outline"
                  isLink={true}
                  href={report.href}
                  class="w-fit"
                >
                  Read Report
                </Button>
              </div>
            </a>
          ))
        }
      </div>

      <div class="text-center pt-8 border-t border-base-200">
        <Button
          variant="default"
          size="base"
          isLink={true}
          href="/reports"
        >
          View All Reports
        </Button>
      </div>
    </div>
  </Wrapper>
</section>
