---
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const pillars = [
  { title: "Human Capacity", description: "Do your teams have the skills to succeed with AI?" },
  { title: "Cultural Alignment", description: "Is your organization truly ready for transformation?" },
  { title: "Adoption Infrastructure", description: "Do you have systems in place to sustain change?" },
  { title: "Integration Feasibility", description: "Can your technology stack support this shift?" },
  { title: "Financial Sustainability", description: "Are you investing adequately for long-term success?" },
];
---

<section>
  <Wrapper variant="standard" class="py-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Left: Hero Section -->
      <div
        class="relative h-96 lg:h-full min-h-[500px] rounded-3xl overflow-hidden bg-base-900"
        style="background-image: linear-gradient(135deg, rgba(45, 45, 65, 0.8) 0%, rgba(30, 30, 50, 0.8) 100%);"
      >
        <div class="relative z-10 p-8 lg:p-12 h-full flex flex-col justify-between">
          <div>
            <Text
              tag="h2"
              variant="displayLG"
              class="text-white font-display mb-8"
            >
              Capability Assessment
            </Text>
            <Text
              tag="p"
              variant="textLG"
              class="text-white/90 leading-relaxed"
            >
              Using the HCAIF framework, we assess readiness across five dimensions: human capacity, cultural alignment, adoption infrastructure, integration feasibility, and financial sustainability. Then we build capability systematically.
            </Text>
          </div>
          <div>
            <Button
              isLink
              size="xs"
              variant="muted"
              href="/assessment"
              class="w-fit"
            >
              Start Assessment
            </Button>
          </div>
        </div>
      </div>

      <!-- Right: Pillars Cards -->
      <div class="flex flex-col gap-4 max-h-[480px] overflow-y-auto pr-4">
        {pillars.map((pillar) => (
          <div class="p-6 lg:p-8 rounded-2xl bg-base-50 hover:bg-base-100 transition-colors">
            <Text
              tag="span"
              variant="textXS"
              class="text-base-600 uppercase font-medium"
            >
              Framework
            </Text>
            <Text
              tag="h3"
              variant="textLG"
              class="text-base-900 font-semibold mt-4 mb-2"
            >
              {pillar.title}
            </Text>
            <Text
              tag="p"
              variant="textBase"
              class="text-base-700"
            >
              {pillar.description}
            </Text>
          </div>
        ))}
      </div>
    </div>
  </Wrapper>
</section>
