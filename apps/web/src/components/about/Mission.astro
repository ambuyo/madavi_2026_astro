---
// Assets
import { Image } from "astro:assets";
import talk from "@/images/assets/talk.png";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const features = [
  {
    title: "Human-Centric, Always.",
    description:
      "Technology should amplify human potential, not replace it. Every system we build preserves the human touch where it matters most—while removing the drudgery that doesn't.",
  },
  {
    title: "Practical Over Theoretical.",
    description:
      "We don't sell AI dreams. We deliver working systems. Our solutions are deployed, tested, and optimized in real business environments before we call them done.",
  },
  {
    title: "Partnership, Not Projects.",
    description:
      "Automation isn't a one-time implementation—it's an ongoing capability. We stay involved, educating your team and evolving your systems as your business grows.",
  },
  {
    title: "Accountability Through Transparency.",
    description:
      "You'll always know what we're building, why we're building it, and what value it delivers. No black boxes. No buzzword smoke screens.",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-12">
    <div
      class="grid md:grid-cols-2 lg:grid-cols-2 gap-8 p-8 lg:p-12 bg-base-50"
    >
      <div class="flex flex-col">
        <div>
          <Text
            tag="h2"
            variant="displayMD"
            class="text-base 950 text-balance font-medium tracking-tight font-display mt-8"
          >
           Our Mission

          </Text>
          <Text
            tag="p"
            variant="textBase"
            class="text-base-700 mt-2 text-pretty"
          >
To make intelligent automation accessible, practical, and transformative for businesses ready to lead in the AI Age.
          </Text>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-y-12 gap-x-8 mt-12">
          {
            features.map((feature) => (
              <div>
                <Text
                  tag="h3"
                  variant="textLG"
                  class="text-base-900 font-display"
                >
                  {feature.title}
                </Text>
                <Text
                  tag="p"
                  variant="textSM"
                  class="text-base-600 mt-2 text-pretty"
                >
                  {feature.description}
                </Text>
              </div>
            ))
          }
        </div>
      </div>
      <Image
        src={talk}
        alt="Image"
        width={800}
        height={1440}
        loading="eager"
        decoding="async"
        class="size-full object-cover object-center aspect-square"
      />
    </div>
  </Wrapper>
</section>
