---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const stats = [
  {
    number: "500+",
    label: "Happy Clients",
  },
  {
    number: "10+",
    label: "Years Experience",
  },
  {
    number: "99%",
    label: "Client Satisfaction",
  },
  {
    number: "24/7",
    label: "Support Available",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-12 lg:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-start">
      <Kicker variant="default">Our story</Kicker>
      <Text
        tag="h2"
        variant="textLG"
        class="text-base-900 lg:text-pretty lg:col-span-2 lg:-mt-2 font-medium font-display"
      >
        Founded in 2010, Mulberry Accounting has been at the forefront of
        financial excellence for over a decade. What started as a small practice
        with a vision to revolutionize accounting services has grown into a
        trusted partner for businesses across industries.
      </Text>
      <div class="lg:col-span-2 lg:-mt-2">
        <Text tag="p" variant="textBase" class="text-base-600 lg:text-pretty">
          Our journey began with a simple belief: that every business deserves
          access to world-class financial expertise. Today, we serve hundreds of
          clients, from startups to established enterprises, providing the
          insights and support they need to make informed decisions and achieve
          sustainable growth.
          <br />
          <br />
          Through years of dedication and continuous learning, we've built a reputation
          for integrity, accuracy, and innovative solutions that drive real results.
        </Text>
      </div>
    </div>
    <div
      class="grid grid-cols-1 lg:grid-cols-4 gap-4 lg:gap-y-12 mt-12 lg:mt-24"
    >
      {
        stats.map((stat) => (
          <div>
            <Text
              tag="p"
              variant="displayXL"
              class="text-base-900  font-display"
            >
              {stat.number}
            </Text>
            <div class="pt-4 mt-4 border-t  border-base-100">
              <Text
                tag="h3"
                variant="textBase"
                class="text-base-900 font-medium "
              >
                {stat.label}
              </Text>
            </div>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
