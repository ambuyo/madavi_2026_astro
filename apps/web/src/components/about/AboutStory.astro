---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const stats = [
  {
    number: "60+",
    label: "businesses launched and scaled online",
  },
  {
    number: "3+",
    label: "3 continents and 3 offices we are set up in",
  },
  {
    number: "20m+",
    label: "in USD revenue contributed to our partners' growth",
  },
  {
    number: "2018",
    label: "Founded with Regional roots, global reach",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-12 lg:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-start">
      <Kicker variant="default">Our story</Kicker>
      <Text
        tag="h2"
        variant="textLG"
        class="text-base-900 lg:text-pretty lg:col-span-2 lg:-mt-2 font-medium font-display"
      >
        For nearly a decade, we built brands and drove growth. Now, we build the systems that make growth sustainable across critical industries. 

      </Text>
      <div class="lg:col-span-2 lg:-mt-2">
        <Text tag="p" variant="textBase" class="text-base-600 lg:text-pretty">
         For 8+ years, we were Madavi Agency—a digital marketing powerhouse focused on helping businesses stand out and win. We launched brands, shaped digital journeys, and delivered measurable results for over 60 partners.
          <br />
          <br />
         But as we worked with more clients, we noticed a critical pattern: the same talented teams we helped attract attention were drowning in repetitive, manual tasks. Chasing payments. Sending reminders. Copying data. Following up with leads. Necessary work—but work that drained time and energy from real growth.

        </Text>
      </div>
    </div>
    <div
      class="grid grid-cols-1 lg:grid-cols-4 gap-4 lg:gap-y-12 mt-12 lg:mt-24"
    >
      {
        stats.map((stat) => (
          <div>
            <Text
              tag="p"
              variant="displayXL"
              class="text-base-900  font-display"
            >
              {stat.number}
            </Text>
            <div class="pt-4 mt-4 border-t  border-base-100">
              <Text
                tag="h3"
                variant="textBase"
                class="text-base-900 font-medium "
              >
                {stat.label}
              </Text>
            </div>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
