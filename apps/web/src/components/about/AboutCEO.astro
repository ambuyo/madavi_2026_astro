---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const certifications = [
  "CPA Certified",
  "MBA Finance",
  "CFA Charterholder",
  "CMA Certified",
  "PFS Credentialed",
];
---

<sectio>
  <Wrapper variant="standard" class="py-12">
    <Text
      tag="h2"
      variant="displayMD"
      class="text-base-900 text-balance font-display"
    >
      A Message from Our CEO
    </Text>
    <div
      class="relative group bg-base-50 grid grid-cols-1 lg:grid-cols-3 gap-4 mt-12"
    >
      <video
        class="object-cover object-center w-full aspect-square h-full"
        controls
        preload="metadata"
      >
        <source src="/ceo.mp4" type="video/mp4" />
        <source src="/ceo.webm" type="video/webm" />
      </video>
      <div class="lg:col-span-2 p-8 grid grid-cols-1 gap-8 lg:grid-cols-3">
        <div class="flex flex-col h-full justify-between lg:col-span-2 gap-8">
          <Text
            tag="p"
            variant="textLG"
            class="text-base-900 font-medium leading-relaxed"
          >
            With over 15 years of experience in financial leadership, Sarah
            founded Mulberry Accounting with a vision to provide personalized,
            technology-driven accounting services that help businesses thrive in
            an increasingly complex financial landscape.
          </Text>
          <div>
            <Text tag="p" variant="textXL" class="text-base-900 font-display">
              Sarah Johnson
            </Text>
            <Text tag="p" variant="textSM" class="text-base-600 mt-1">
              CEO & Founder, Mulberry Accounting
            </Text>
          </div>
        </div>
        <div
          class="lg:border-l lg:pl-8 flex flex-col h-full border-base-100 order-first lg:order-none"
        >
          <div class="space-y-1 mt-auto">
            {
              certifications.map((cert) => (
                <Text tag="span" variant="textSM" class="text-base-600 block">
                  {cert}
                </Text>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </Wrapper>
</sectio>
