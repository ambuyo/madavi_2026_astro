---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";

const { post } = Astro.props;
const { name, slug, industry, summary, publicationDate, featuredImage } = post;
const url = `/resources/reports/${slug.current}`;
const year = new Date(publicationDate).getFullYear();
---

<article class="flex flex-col group h-full rounded-2xl bg-base-50 overflow-hidden hover:shadow-md transition-shadow duration-200">
  {featuredImage && featuredImage.asset && (
    <a href={url} class="relative block overflow-hidden h-40 bg-base-100">
      <img
        src={featuredImage.asset.url}
        alt={featuredImage.alt || name}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
    </a>
  )}

  <div class="flex flex-col flex-grow p-6">
    <Text
      tag="p"
      variant="textXS"
      class="text-secondary-500 uppercase font-medium"
    >
      {industry} • {year}
    </Text>

    <a href={url} class="group/link mt-3">
      <Text
        tag="h3"
        variant="displaySM"
        class="text-accent-800 font-display group-hover/link:text-accent-900 transition-colors"
      >
        {name}
      </Text>
    </a>

    <Text tag="p" variant="textSM" class="text-base-600 mt-2 line-clamp-2 flex-grow">
      {summary}
    </Text>

    <a
      href={url}
      class="text-accent-600 hover:text-accent-700 font-medium text-xs mt-4 inline-block"
    >
      Read Report →
    </a>
  </div>
</article>
