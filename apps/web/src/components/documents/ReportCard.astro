---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";

const { post } = Astro.props;
const { name, slug, industry, summary, publicationDate, reportCoverImage } = post;

if (!slug || !slug.current) {
  throw new Error(`Report "${name}" is missing a slug. Please add a slug in Sanity Studio.`);
}

const url = `/resources/reports/${slug.current}`;
const date = new Date(publicationDate).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a href={url} class="flex flex-col group h-full bg-white border border-base-200 hover:shadow-lg transition-shadow duration-300">
  {/* Report Cover Image */}
  {reportCoverImage && reportCoverImage.asset && (
    <div class="relative overflow-hidden bg-base-100 flex-shrink-0" style="aspect-ratio: 3/4;">
      <img
        src={reportCoverImage.asset.url}
        alt={reportCoverImage.alt || name}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
    </div>
  )}

  {/* Content */}
  <div class="flex flex-col flex-grow p-6">
    {/* Title */}
    <Text
      tag="h3"
      variant="textBase"
      class="text-base-900 font-semibold group-hover:text-accent-600 transition-colors line-clamp-3"
    >
      {name}
    </Text>

    {/* Description */}
    <Text tag="p" variant="textSM" class="text-base-600 mt-3 line-clamp-3 flex-grow">
      {summary}
    </Text>

    {/* Metadata - Author */}
    <div class="mt-6 pt-6 border-t border-base-100">
      <Text
        tag="p"
        variant="textXS"
        class="text-base-700 font-medium"
      >
        {industry}
      </Text>

      {/* Date */}
      <Text
        tag="p"
        variant="textXS"
        class="text-base-600 mt-1"
      >
        {date}
      </Text>
    </div>
  </div>
</a>
