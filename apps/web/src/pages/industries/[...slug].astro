---
import IndustriesLayout from "@/layouts/IndustriesLayout.astro";
import { getIndustries, getIndustryBySlug } from "@/lib/data";

export async function getStaticPaths() {
  const industries = await getIndustries();
  return industries.map((industry) => ({
    params: { slug: industry.slug },
  }));
}

const { slug } = Astro.params;
const industry = await getIndustryBySlug(slug!);
if (!industry) {
  return Astro.redirect("/404");
}
const Content = industry.render ? (await industry.render()).Content : null;

const seo = {
  title: industry.data.title,
  description: industry.data.summary || `Discover how Madavi serves the ${industry.data.title} industry with specialized AI consulting and digital transformation services.`,
  image: industry.data.image,
  type: "article" as const,
};
---

<IndustriesLayout frontmatter={industry.data} seo={seo}>
  {Content ? <Content /> : <div set:html={industry.body} />}
</IndustriesLayout>
