---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Contact Components
import ContactHero from "@/components/contact/ContactHero.astro";
import ContactMain from "@/components/contact/ContactMain.astro";

const officeLocations = [
  {
    name: "Nairobi",
    address: "Nairobi Tech Hub, Tom Mboya Street",
    city: "Nairobi, Kenya",
    phone: "(254) 718-735-565",
    email: "nairobi@madavi.co",
    coordinates: { lat: -1.2865, lng: 36.8172 },
  },
  {
    name: "Kigali",
    address: "Kigali Innovation District, Boulevard de la Révolution",
    city: "Kigali, Rwanda",
    phone: "(555) 234-5678",
    email: "kigali@madavi.co",
    coordinates: { lat: -1.9536, lng: 30.0588 },
  },
  {
    name: "Wilmington",
    address: "2595, 1007 N Orange St. 4th Floor",
    city: "Wilmington, DE 19801, USA",
    phone: "(555) 345-6789",
    email: "contact@madavi.co",
    coordinates: { lat: 39.7390, lng: -75.5453 },
  },
];
---
<BaseLayout>
  <ContactHero />
  <ContactMain />

  <Wrapper variant="standard" class="py-12">
    <div>
      <Text
        tag="h2"
        variant="displayMD"
        class="text-accent-800 font-display text-balance"
      >
        Our Offices
      </Text>
      <div class="grid grid-cols-1 lg:grid-cols-2 mt-12 gap-8">
        {
          officeLocations.map((office) => (
            <div class="bg-base-50 gap-8">
              <div class="p-8">
                <Text
                  tag="h3"
                  variant="displaySM"
                  class="text-accent-800 font-display"
                >
                  {office.name}
                </Text>
                <div class="space-y-1 text-sm text-base-700 mt-8">
                  <Text tag="p" variant="textXS">
                    {office.address}
                  </Text>
                  <Text tag="p" variant="textXS">
                    {office.city}
                  </Text>
                  <a
                    href={`tel:${office.phone}`}
                    class="text-secondary-500 hover:text-accent-800 transition-colors text-xs block"
                  >
                    {office.phone}
                  </a>
                  <a
                    href={`mailto:${office.email}`}
                    class="text-secondary-500 hover:text-accent-800 transition-colors text-xs block"
                  >
                    {office.email}
                  </a>
                </div>
              </div>
              <div class="aspect-video overflow-hidden">
                <iframe
                  src={`https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3024.221990489111!2d${office.coordinates.lng}!3d${office.coordinates.lat}!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c25a316ba4bf83%3A0xbae5cb597764b!2s${encodeURIComponent(office.address + ", " + office.city)}!5e0!3m2!1sen!2sus!4v1696871234567!5m2!1sen!2sus`}
                  width="100%"
                  height="100%"
                  style="border:0;"
                  allowfullscreen=""
                  loading="eager"
                  referrerpolicy="no-referrer-when-downgrade"
                  title={`Map of ${office.name}`}
                />
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </Wrapper>
</BaseLayout>
