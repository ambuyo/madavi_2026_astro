---
// Assets
import { Image } from "astro:assets";
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import Seo from "@/components/fundations/head/Seo.astro";
// Data
import { getPosts, getPostBySlug } from "@/lib/data";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = await getPostBySlug(slug!);

if (!post) {
  return Astro.redirect("/404");
}

function formatDate(date: Date): string {
  const day = date.getDate();
  const month = date.toLocaleString("default", { month: "long" });
  const year = date.getFullYear();
  const weekday = date.toLocaleString("default", { weekday: "short" });
  return `${weekday}, ${day} of ${month} ${year}`;
}

function stripHtml(html: string): string {
  return html.replace(/<[^>]*>/g, "").trim();
}
---

<BaseLayout>
  <Seo
    title={post.data.title}
    description={post.data.description || stripHtml(post.plainText || "")}
    image={post.data.image.url}
    type="article"
    publishedTime={post.data.pubDate.toISOString()}
  />

  <article>
    <Wrapper variant="standard" class="py-12">
      <div class="max-w-3xl mx-auto">
        <Text
          tag="h1"
          variant="displayLG"
          class="text-base-900 text-balance font-medium tracking-tight font-display"
        >
          {post.data.title}
        </Text>

        <div class="flex items-center gap-4 mt-8 text-sm text-base-600">
          <time datetime={post.data.pubDate.toISOString()}>
            {formatDate(post.data.pubDate)}
          </time>
          {post.data.categories && post.data.categories.length > 0 && (
            <>
              <span>•</span>
              <span>{post.data.categories[0].name}</span>
            </>
          )}
        </div>

        {post.data.image.url && (
          <div class="mt-12 rounded-lg overflow-hidden">
            <Image
              src={post.data.image.url}
              alt={post.data.image.alt || post.data.title}
              width={800}
              height={400}
              class="w-full aspect-video object-cover object-center"
            />
          </div>
        )}

        <div class="mt-12 prose prose-base max-w-none">
          <div
            class="text-base-700 leading-relaxed space-y-4"
            set:html={post.body}
          />
        </div>
      </div>
    </Wrapper>
  </article>
</BaseLayout>
