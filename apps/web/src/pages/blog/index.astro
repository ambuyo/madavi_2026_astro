---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import BlogCard from "@/components/blog/BlogCard.astro";
import BigBlogCard from "@/components/blog/BigBlogCard.astro";
import PostsCategoryCard from "@/components/blog/PostsCategoryCard.astro";
// Data
import { getPosts } from "@/lib/data";
const allPosts = await getPosts();
allPosts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});

const featuredPost = allPosts[0];
const remainingPosts = allPosts.slice(1, 3);

const seo = {
  title: "Blog",
  description: "Read insights and articles about AI consulting, digital transformation, and business strategy from Madavi.",
  type: "website" as const,
};

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Madavi Blog",
  "headline": "Honest AI Advice for Business Leaders",
  "description": "Real AI implementation insights for business leaders. No hype, no vendor pitches—just honest advice from deploying AI in law firms, hospitals, and African enterprises.",
  "url": "https://madavi.co/blog/",
  "publisher": {
    "@type": "Organization",
    "name": "Madavi Inc.",
    "logo": {
      "@type": "ImageObject",
      "url": "https://madavi.co/images/madavi-logo.png"
    }
  },
  "author": {
    "@type": "Person",
    "name": "Amukune"
  },
  "inLanguage": "en-US",
  "keywords": "AI adoption, AI implementation, business AI, AI for law firms, AI for healthcare, AI for nonprofits, AI for retail, AI for African enterprises"
};
---

<BaseLayout seo={seo}>
  <section>
    <Wrapper variant="standard" class="py-12">
      <div class="max-w-2xl">
        <Kicker variant="default">Our Insights</Kicker>
        <Text
          tag="h1"
          variant="displayLG"
          class="text-base-900 text-balance font-medium tracking-tight mt-8 font-display"
        >
          Honest AI Advice for Business Leaders 
        </Text>
        <Text
          tag="p"
          variant="textBase"
          class="text-base-600 lg:text-balance mt-4"
        >
Real AI implementation insights for business leaders. No hype, no vendor pitches—just honest advice from deploying AI in law firms, hospitals, and African enterprises.

        </Text>
      </div>

      {featuredPost && (
        <div class="mt-12">
          <BigBlogCard post={featuredPost} />
        </div>
      )}

      {remainingPosts.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-2 mt-12 gap-2 p-8 lg:p-12 bg-base-50">
          {remainingPosts.map((post) => <BlogCard post={post} />)}
        </div>
      )}
    </Wrapper>

    <PostsCategoryCard
      category="content-marketing"
      categoryTitle="Content Marketing"
    />

        <PostsCategoryCard
      category="growth-marketing"
      categoryTitle="Growth Marketing"
    />

            <PostsCategoryCard
      category="seo-marketing"
      categoryTitle="SEO Marketing"
    />

  </section>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
</BaseLayout>
