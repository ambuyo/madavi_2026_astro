---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
// Landing Components
import HOAHero from "@/components/landing/HOAHero.astro";
import HeroVT2 from "@/components/landing/HeroVT2.astro";
import Stats1 from "@/components/stats/Stats1.astro";
import ValueStatement from "@/components/landing/ValueStatement.astro";
import ServicesOverview from "@/components/landing/ServicesPreview.astro";
import IndustriesOverview from "@/components/landing/IndustriesPreview.astro";
import CaseStudiesPreview from "@/components/landing/CaseStudiesPreview.astro";
import Why from "@/components/landing/Why.astro";
import TestimonialsPreview from "@/components/landing/TestimonialsPreview.astro";

import LatestReports from "@/components/landing/LatestReports.astro";
import BlogPreview from "@/components/landing/BlogPreview.astro";

const seo = {
  title: "AI Consulting & Digital Transformation",
  description: "Transform your business with AI-driven strategy and implementation. Madavi helps organizations leverage AI for competitive advantage.",
  type: "website" as const,
};
---

<BaseLayout seo={seo}>
  <HOAHero />
  <HeroVT2 />
  <Stats1 />
  <ValueStatement />
  <ServicesOverview />
  <Why />
  <IndustriesOverview />
  <CaseStudiesPreview />
  <TestimonialsPreview />
  <LatestReports />
  <BlogPreview />
</BaseLayout>
