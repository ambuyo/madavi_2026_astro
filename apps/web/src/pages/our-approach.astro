---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
// Our Approach Components
import ApproachHero from "@/components/our-approach/ApproachHero.astro";
import ApproachOld from "@/components/our-approach/ApproachOld.astro";
import ThreePillarEngagement from "@/components/our-approach/3PillarEngagement.astro";
import ApproachPricing from "@/components/our-approach/ApproachPricing.astro";
import SuccessMetrics from "@/components/our-approach/SuccessMetrics.astro";
import ApproachEngagementPhases from "@/components/our-approach/ApproachEngagementPhases.astro";
import FailureMetrics from "@/components/our-approach/FailureMetrics.astro";

const seo = {
  title: "Our Approach",
  description: "Learn about our approach to AI consulting and digital transformation.",
  type: "website" as const,
};
 
---

<BaseLayout seo={seo}>
  <ApproachHero />
  <ApproachOld />
  <ThreePillarEngagement />
  <ApproachEngagementPhases />
  <SuccessMetrics />
  <FailureMetrics />

  <ApproachPricing />
</BaseLayout>
