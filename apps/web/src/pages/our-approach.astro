---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
// Our Approach Components
import ApproachHero from "@/components/our-approach/ApproachHero.astro";
import ApproachTimeline from "@/components/our-approach/ApproachTimeline.astro";
import ApproachOld from "@/components/our-approach/ApproachOld.astro";
import ThreePillarEngagement from "@/components/our-approach/3PillarEngagement.astro";
import ApproachTraditional from "@/components/our-approach/ApproachTraditional.astro";
import AboutStory from "@/components/our-approach/AboutStory.astro";
import AboutMission from "@/components/our-approach/AboutMission.astro";
import AboutCEO from "@/components/our-approach/AboutCEO.astro";
import AboutTeam from "@/components/our-approach/AboutTeam.astro";
import ApproachPricing from "@/components/our-approach/ApproachPricing.astro";
import Evolution from "@/components/our-approach/Evolution.astro";
import Mission from "@/components/our-approach/Mission.astro";
import Methodology from "@/components/our-approach/Methodology.astro";

const seo = {
  title: "Our Approach",
  description: "Learn about our approach to AI consulting and digital transformation.",
  type: "website" as const,
