---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
// About Components
import AboutHero from "@/components/about/AboutHero.astro";
import AboutStory from "@/components/about/AboutStory.astro";
import AboutMission from "@/components/about/AboutMission.astro";
import AboutCEO from "@/components/about/AboutCEO.astro";
import AboutTeam from "@/components/about/AboutTeam.astro";
import Why from "@/components/landing/Why.astro";
import Evolution from "@/components/about/Evolution.astro";
import Mission from "@/components/about/Mission.astro";
import Methodology from "@/components/about/Methodology.astro";
import OurHistory from "@/components/about/OurHistory.astro";

const seo = {
  title: "About Us",
  description: "Learn about Madavi's mission, team, and approach to AI consulting and digital transformation. Discover our values and expertise.",
  type: "website" as const,
};

---

<BaseLayout seo={seo}>
  <AboutHero />
  <AboutStory />
  <OurHistory />
  <Evolution />
  <AboutMission />
  <Mission />
  <Methodology />
  <AboutCEO />
  <AboutTeam />
</BaseLayout>
