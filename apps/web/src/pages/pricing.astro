---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
// Pricing Components
import PricingHero from "@/components/pricing/PricingHero.astro";
import PricingPackages from "@/components/pricing/PricingPackages.astro";
import IndividualServices from "@/components/pricing/IndividualServices.astro";
import PricingFAQ from "@/components/pricing/PricingFAQ.astro";

const seo = {
  title: "Pricing",
  description: "Transparent pricing for AI consulting services. Explore our flexible service packages and investment options.",
  type: "website" as const,
};
---

<BaseLayout seo={seo}>
  <PricingHero />
  <PricingPackages />
  <IndividualServices />
  <PricingFAQ />
</BaseLayout>
