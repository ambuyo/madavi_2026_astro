---
// Assets
import { Image } from "astro:assets";
import testimonial1 from "@/images/assets/testimonial.png";
import testimonial2 from "@/images/assets/testimonial2.png";
import testimonial3 from "@/images/assets/testimonial3.png";
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

// Testimonials Data
const testimonials = [
  {
    quote:
      "Mulberry  transformed our financial operations completely. Their expertise in tax planning saved us thousands, and their bookkeeping accuracy gave us confidence in our financial reports. Truly professional and reliable partners.",
    author: "Shaun Smith",
    role: "CEO, Tribeca",
    metric: "100%",
    metricLabel: "Match rate.",
    image: testimonial1,
  },
  {
    quote:
      "The Mulberry  team provided exceptional CFO services that helped us scale our business. Their strategic financial guidance was instrumental in our successful expansion and helped us secure additional funding.",
    author: "Sonia Perez",
    role: "Founder, TechStart Inc.",
    metric: "250%",
    metricLabel: "Revenue growth",
    image: testimonial2,
  },
  {
    quote:
      "Working with Mulberry  has been a game-changer for our non-profit. Their expertise in tax-exempt organization accounting and their commitment to our mission made all the difference.",
    author: "Kristopher Lawrence",
    role: "Executive Director, Community Aid",
    metric: "95%",
    metricLabel: "Compliance rate",
    image: testimonial3,
  },
];
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-12 lg:py-24">
      <div class="max-w-2xl">
        <Kicker variant="default">Testimonials</Kicker>
        <Text
          tag="h1"
          variant="displayLG"
          class="text-base-900 text-balance font-medium tracking-tight mt-8 font-display"
        >
          What Our Clients Say
        </Text>
        <Text
          tag="p"
          variant="textBase"
          class="text-base-600 lg:text-balance mt-4"
        >
          Don't just take our word for it. Hear directly from the business
          owners and executives who've experienced the Mulberry difference
          firsthand.
        </Text>
      </div>

      <div class="space-y-8 lg:space-y-24 mt-12 lg:mt-24">
        {
          testimonials.map((testimonial, index) => (
            <article class="relative group bg-base-50 grid grid-cols-1 lg:grid-cols-3 gap-4 ">
              <Image
                src={testimonial.image}
                alt={`${testimonial.author} testimonial`}
                width={800}
                height={600}
                loading="eager"
                decoding="async"
                class="object-cover object-center w-full aspect-square"
              />
              <div class="lg:col-span-2 p-8 grid grid-cols-1 gap-8 lg:grid-cols-3">
                <div class="flex flex-col h-full justify-between lg:col-span-2 gap-8">
                  <blockquote>
                    <Text
                      tag="p"
                      variant="textLG"
                      class="text-base-900 font-medium leading-relaxed"
                    >
                      "{testimonial.quote}"
                    </Text>
                  </blockquote>
                  <div>
                    <Text
                      tag="p"
                      variant="textXL"
                      class="text-base-900 font-display"
                    >
                      {testimonial.author}
                    </Text>
                    <Text tag="p" variant="textSM" class="text-base-600 mt-1">
                      {testimonial.role}
                    </Text>
                  </div>
                </div>
                <div class="lg:border-l lg:pl-8 flex flex-col h-full border-base-100 order-first lg:order-none">
                  <Text
                    tag="p"
                    variant="displayXL"
                    class="text-base-900 font-display mt-auto"
                  >
                    {testimonial.metric}
                  </Text>
                  <div class="pt-4 mt-4 border-t border-base-100">
                    <Text
                      tag="h3"
                      variant="textBase"
                      class="text-base-900 font-medium"
                    >
                      {testimonial.metricLabel}
                    </Text>
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </Wrapper>
  </section>
</BaseLayout>
