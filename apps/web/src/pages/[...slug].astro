---
import BlogLayout from "@/layouts/BlogLayout.astro";
import { getPostBySlug } from "@/lib/data";
import { readCachedPosts } from "@/lib/wordpress/cache";
import { transformWordPressPost } from "@/lib/wordpress/transforms";

export async function getStaticPaths() {
  try {
    // Use cached posts for static generation to avoid API calls during build
    const cachedPosts = await readCachedPosts();

    if (!cachedPosts || cachedPosts.length === 0) {
      console.warn("No cached posts found. Skipping static path generation.");
      return [];
    }

    return cachedPosts.map((post) => ({
      params: { slug: post.slug },
    }));
  } catch (error) {
    console.error("Error generating static paths:", error);
    return [];
  }
}

const { slug } = Astro.params;
const post = await getPostBySlug(slug!);
if (!post) {
  return Astro.redirect("/404");
}
const Content = post.render ? (await post.render()).Content : null;

const seo = {
  title: post.data.title,
  description: post.data.description,
  image: post.data.image,
  type: "article" as const,
  publishedTime: post.data.pubDate?.toISOString(),
};
---

<BlogLayout frontmatter={post.data} seo={seo}>
  {Content ? <Content /> : <div set:html={post.body} />}
</BlogLayout>
