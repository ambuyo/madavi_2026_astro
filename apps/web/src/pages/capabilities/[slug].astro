---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
// AI Components
import ReadinessHero from "@/components/capabilities/ai/ReadinessHero.astro";
import ReadinessFailurePoints from "@/components/capabilities/ai/ReadinessFailurePoints.astro";
import ReadinessBarriersCombat from "@/components/capabilities/ai/ReadinessBarriersCombat.astro";
import ReadinessVerticalCarousels from "@/components/capabilities/ai/ReadinessVerticalCarousels.astro";
import AIServicesFAQ from "@/components/capabilities/ai/AIServicesFAQ.astro";
import ReadinessValueSteps from "@/components/capabilities/ai/ReadinessValueSteps.astro";
// Agency Components
import AgencyHero from "@/components/capabilities/agency/AgencyHero.astro";
import AgencyFailurePoints from "@/components/capabilities/agency/AgencyFailurePoints.astro";
import AgencyBarriersCombat from "@/components/capabilities/agency/AgencyBarriersCombat.astro";
import AgencyVerticalCarousels from "@/components/capabilities/agency/AgencyVerticalCarousels.astro";
import AgencyServicesFAQ from "@/components/capabilities/agency/AgencyServicesFAQ.astro";
import AgencyValueSteps from "@/components/capabilities/agency/AgencyValueSteps.astro";

export async function getStaticPaths() {
  const capabilities = await getCollection("capabilities");
  return capabilities.map((capability: any) => ({
    params: { slug: capability.data.slug },
    props: { capability: capability.data },
  }));
}

interface Props {
  capability: {
    title: string;
    description: string;
    slug: string;
    pageTitle?: string;
    seoMetaDescription?: string;
    hero?: any;
    barriers: any[];
    barrierSection?: any;
    programs: any[];
    highlights: any[];
    valueSteps: any[];
    carouselSections: any[];
    faqs: any[];
  };
}

const { capability } = Astro.props;

// Determine which component set to use based on slug
const isAIService = ['ai-readiness', 'executive-advisory', 'leadership-cohort', 'keynotes-licensing'].includes(capability.slug);

const HeroComponent = isAIService ? ReadinessHero : AgencyHero;
const FailurePointsComponent = isAIService ? ReadinessFailurePoints : AgencyFailurePoints;
const BarriersCombatComponent = isAIService ? ReadinessBarriersCombat : AgencyBarriersCombat;
const VerticalCarouselsComponent = isAIService ? ReadinessVerticalCarousels : AgencyVerticalCarousels;
const FAQComponent = isAIService ? AIServicesFAQ : AgencyServicesFAQ;
const ValueStepsComponent = isAIService ? ReadinessValueSteps : AgencyValueSteps;
---

<BaseLayout
  title={capability.title}
  description={capability.description}
>
  <HeroComponent
    title={capability.title}
    subtitle={capability.hero?.subtitle}
    description={capability.hero?.description}
  />
  <FailurePointsComponent
    failures={capability.barriers}
    barrierTitle={capability.barrierSection?.title}
    barrierHeading={capability.barrierSection?.heading}
    barrierDescription={capability.barrierSection?.description}
  />
  <BarriersCombatComponent programs={capability.programs} />
  <VerticalCarouselsComponent sections={capability.carouselSections?.[0]?.items} />
  <ValueStepsComponent steps={capability.valueSteps} />
  <FAQComponent faqSlug={capability.slug} />
</BaseLayout>
