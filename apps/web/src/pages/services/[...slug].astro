---
import ServicesLayout from "@/layouts/ServicesLayout.astro";
import { getServices, getServiceBySlug } from "@/lib/data";

export async function getStaticPaths() {
  const services = await getServices();
  return services.map((service) => ({
    params: { slug: service.slug },
  }));
}

const { slug } = Astro.params;
const service = await getServiceBySlug(slug!);
if (!service) {
  return Astro.redirect("/404");
}
const Content = service.render ? (await service.render()).Content : null;
---

<ServicesLayout frontmatter={service.data}>
  {Content ? <Content /> : <div set:html={service.body} />}
</ServicesLayout>
