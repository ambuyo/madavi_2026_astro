---
import { getCollection } from "astro:content";

const faqEntries = await getCollection("faqs");
const postsEntries = await getCollection("posts");
---

<html>
<body>
  <h1>Collection Debug</h1>
  <p>FAQs count: {faqEntries.length}</p>
  <p>Posts count: {postsEntries.length}</p>

  {faqEntries.length > 0 && (
    <div>
      <h2>FAQs:</h2>
      {faqEntries.map(entry => (
        <p>{entry.data.title} - {entry.data.slug}</p>
      ))}
    </div>
  )}
</body>
</html>
