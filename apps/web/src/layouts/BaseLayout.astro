---
// Fundations
import "@/styles/global.css";
import BaseHead from "@/components/fundations/head/BaseHead.astro";
// Components
import MainCta from "@/components/ctas/MainCta.astro";
import Footer from "@/components/global/Footer.astro";
import Navigation from "@/components/global/Navigation.astro";
// Components
import Search from "@/components/global/Search.astro";

interface Props {
  seo?: {
    title?: string;
    description?: string;
    image?: { url: string; alt?: string };
    type?: "website" | "article";
    publishedTime?: string;
    noindex?: boolean;
  };
  hideNavigation?: boolean;
  hideFooter?: boolean;
}

// Hides the navigation, or footer on selected screens by passing props:
// <BaseLayout hideNavigation={true} hideFooter={true}>
const {
  seo,
  hideMainCta = false,
  hideNavigation = false,
  hideFooter = false,
} = Astro.props;
---

<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead seo={seo} />
  </head>
  <body class="flex flex-col bg-white min-h-svh pt-24">
    {!hideNavigation && <Navigation />}
    <main class="grow"><slot /></main>
    {!hideFooter && <MainCta />}
    {!hideFooter && <Footer />}
    <Search />
  </body>
</html>
