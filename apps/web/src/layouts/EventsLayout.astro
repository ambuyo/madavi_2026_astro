---
import BaseLayout from "@/layouts/BaseLayout.astro";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Button from "@/components/fundations/elements/Button.astro";
// Icons
import ArrowRight from "@/components/fundations/icons/ArrowRight.astro";

export interface Props {
  frontmatter: {
    title: string;
    description: string;
    startDate: Date;
    endDate: Date;
    location: string;
    url?: string;
  };
}

const { frontmatter } = Astro.props;

const formattedStartDate = frontmatter.startDate.toLocaleDateString("en-US", {
  weekday: "long",
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedStartTime = frontmatter.startDate.toLocaleTimeString("en-US", {
  hour: "numeric",
  minute: "2-digit",
  timeZoneName: "short",
});

const formattedEndTime = frontmatter.endDate.toLocaleTimeString("en-US", {
  hour: "numeric",
  minute: "2-digit",
  timeZoneName: "short",
});
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24 lg:pt-48">
      <div class="grid lg:grid-cols-3 gap-12">
        <div>
          <div class="lg:sticky lg:top-48">
            <Text
              tag="p"
              variant="textXS"
              class="text-secondary-500 uppercase font-medium"
            >
              Event Details
            </Text>
            <Text
              tag="h1"
              variant="displaySM"
              class="text-accent-800 font-display text-balance mt-12"
            >
              {frontmatter.title}
            </Text>
            <Text
              tag="p"
              variant="textSM"
              class="text-base-600 mt-4 leading-relaxed"
            >
              {frontmatter.description}
            </Text>

            <div class="mt-12 space-y-4 bg-base-50 p-6 rounded-2xl">
              <div>
                <Text tag="p" variant="textXS" class="text-base-600 uppercase font-medium">
                  Date
                </Text>
                <Text tag="p" variant="textBase" class="text-accent-800 font-medium mt-1">
                  {formattedStartDate}
                </Text>
              </div>

              <div>
                <Text tag="p" variant="textXS" class="text-base-600 uppercase font-medium">
                  Time
                </Text>
                <Text tag="p" variant="textBase" class="text-accent-800 font-medium mt-1">
                  {formattedStartTime} - {formattedEndTime}
                </Text>
              </div>

              <div>
                <Text tag="p" variant="textXS" class="text-base-600 uppercase font-medium">
                  Location
                </Text>
                <Text tag="p" variant="textBase" class="text-accent-800 font-medium mt-1">
                  {frontmatter.location}
                </Text>
              </div>
            </div>

            <div class="mt-12 space-y-3">
              {
                frontmatter.url && (
                  <Button
                    isLink={true}
                    href={frontmatter.url}
                    target="_blank"
                    variant="default"
                    size="sm"
                    class="w-full flex items-center justify-center gap-2"
                  >
                    Register for Event
                    <ArrowRight class="size-4" />
                  </Button>
                )
              }

              <Button
                isLink={true}
                href="/resources/events"
                variant="muted"
                size="sm"
                class="w-full flex items-center justify-center gap-2"
              >
                Back to Events
                <ArrowRight class="size-4" />
              </Button>
            </div>
          </div>
        </div>

        <div class="lg:col-span-2">
          <div class="prose prose-sm max-w-none">
            <slot />
          </div>
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
